@model WelfareLink.Models.User
@{
    ViewData["Title"] = "Create Officer";
}

<div class="page-header">
    <h1>
        <i class="bi bi-person-plus"></i>
        Create Officer Profile
    </h1>
    <a asp-action="Index" class="btn btn-modern btn-secondary-modern">
        <i class="bi bi-arrow-left"></i> Back to Dashboard
    </a>
</div>

<div class="content-card">
    <form asp-action="CreateOfficer" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Username" class="form-label-modern"></label>
                <input asp-for="Username" class="form-control" placeholder="Enter username" required />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Password" class="form-label-modern"></label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" required />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="FullName" class="form-label-modern"></label>
                <input asp-for="FullName" class="form-control" placeholder="Enter full name" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Email" class="form-label-modern"></label>
                <input asp-for="Email" type="email" class="form-control" placeholder="Enter email address" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Role" class="form-label-modern">Officer Role</label>
            <select asp-for="Role" class="form-select" required>
                <option value="">-- Select Role --</option>
                <option value="WelfareOfficer">Welfare Officer</option>
                <option value="ProgramManager">Program Manager</option>
            </select>
            <span asp-validation-for="Role" class="text-danger"></span>
        </div>

        <div class="d-grid gap-2">
            <button type="submit" class="btn btn-modern btn-primary-modern btn-lg">
                <i class="bi bi-check-circle"></i> Create Officer
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
