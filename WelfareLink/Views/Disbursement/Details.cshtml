@model WelfareLink.Models.Disbursement

@{
    ViewData["Title"] = "Disbursement Details";
}

<div class="page-header">
    <h1><i class="bi bi-info-circle-fill"></i> Disbursement Details</h1>
    <a asp-action="Index" class="btn-modern btn-secondary-modern">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</div>

<div class="content-card">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="rounded-circle bg-success d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                    <i class="bi bi-cash-stack text-white" style="font-size: 1.8rem;"></i>
                </div>
                <div>
                    <h3 class="mb-0">Disbursement #@Model?.DisbursementID</h3>
                    @{
                        var statusClass = Model?.Status?.ToLower() switch
                        {
                            "completed" => "status-completed",
                            "disbursed" => "status-disbursed",
                            "pending" => "status-pending",
                            "failed" => "status-failed",
                            _ => "status-pending"
                        };
                    }
                    <span class="status-badge @statusClass mt-1">
                        <i class="bi bi-circle-fill" style="font-size: 8px;"></i> @Model?.Status
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="detail-grid">
        <div class="detail-item">
            <label><i class="bi bi-hash"></i> Disbursement ID</label>
            <p>@Model?.DisbursementID</p>
        </div>

        <div class="detail-item">
            <label><i class="bi bi-gift"></i> Linked Benefit</label>
            <p>
                @if (Model?.Benefit != null)
                {
                    <span class="badge bg-info">@Model.Benefit.Type</span>
                    <span class="text-muted">- ID: @Model.BenefitID</span>
                }
                else
                {
                    @Model?.BenefitID
                }
            </p>
        </div>

        <div class="detail-item">
            <label><i class="bi bi-person-circle"></i> Citizen ID</label>
            <p>@Model?.CitizenID</p>
        </div>

        <div class="detail-item">
            <label><i class="bi bi-person-badge"></i> Officer ID</label>
            <p>@Model?.OfficerID</p>
        </div>

        <div class="detail-item">
            <label><i class="bi bi-calendar-event"></i> Disbursement Date</label>
            <p>@Model?.Date.ToString("MMMM dd, yyyy")</p>
        </div>

        <div class="detail-item">
            <label><i class="bi bi-flag"></i> Current Status</label>
            <p>@Model?.Status</p>
        </div>
    </div>

    <hr class="my-4" />

    @if (ViewBag.BenefitTotalAmount > 0)
    {
        <div class="alert @(ViewBag.PendingBalance > 0 ? "alert-warning" : "alert-success") mb-4">
            <div class="row g-3 text-center">
                <div class="col-md-4">
                    <small class="text-muted d-block">Benefit Total</small>
                    <strong>₹@(((double)ViewBag.BenefitTotalAmount).ToString("N2"))</strong>
                </div>
                <div class="col-md-4">
                    <small class="text-muted d-block">Total Disbursed</small>
                    <strong class="text-success">₹@(((double)ViewBag.TotalDisbursed).ToString("N2"))</strong>
                </div>
                <div class="col-md-4">
                    <small class="text-muted d-block">Pending Balance</small>
                    <strong class="@(ViewBag.PendingBalance > 0 ? "text-danger" : "text-success")">
                        ₹@(((double)ViewBag.PendingBalance).ToString("N2"))
                        @if (ViewBag.PendingBalance > 0)
                        {
                            <span class="badge bg-danger ms-1">Pending</span>
                        }
                    </strong>
                </div>
            </div>
        </div>
    }

    @{
        var siblings = ViewBag.SiblingDisbursements as IEnumerable<WelfareLink.Models.Disbursement>;
    }
    @if (siblings != null && siblings.Any())
    {
        <h5 class="mb-3"><i class="bi bi-list-check me-2"></i>Other Disbursements for Benefit #@Model?.BenefitID</h5>
        <div class="table-responsive mb-4">
            <table class="table table-sm table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Amount</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sib in siblings)
                    {
                        var sibPending = sib.Status == "Disbursement Pending" || sib.Status == "Pending";
                        <tr class="@(sibPending ? "table-warning" : "")">
                            <td>#@sib.DisbursementID @if (sibPending) { <span class="badge bg-warning text-dark"><i class="bi bi-bell-fill"></i> Action Required</span> }</td>
                            <td>₹@sib.Amount.ToString("N2")</td>
                            <td>@sib.Date.ToString("dd MMM yyyy")</td>
                            <td>@sib.Status</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@sib.DisbursementID" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i> Process
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="d-flex gap-3">
        <a asp-action="Edit" asp-route-id="@Model?.DisbursementID" class="btn-modern btn-warning-modern">
            <i class="bi bi-pencil"></i> Edit Disbursement
        </a>
        <a asp-action="Delete" asp-route-id="@Model?.DisbursementID" class="btn-modern btn-danger-modern">
            <i class="bi bi-trash"></i> Delete
        </a>
        <a asp-action="Index" class="btn-modern btn-secondary-modern">
            <i class="bi bi-list"></i> View All
        </a>
    </div>
</div>
