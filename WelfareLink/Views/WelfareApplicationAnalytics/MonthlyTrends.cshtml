@{
    ViewData["Title"] = "Monthly Trends";
    var currentYear = ViewBag.Year ?? DateTime.Now.Year;
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="display-4">@ViewData["Title"]</h1>
            <p class="lead">Application trends for @currentYear</p>
                </div>
            </div>

            @await Html.PartialAsync("_AnalyticsNav")

            <div class="row mb-3">
                <div class="col-md-12 text-end">
                    <div class="btn-group" role="group">
                <a asp-action="MonthlyTrends" asp-route-year="@(currentYear - 1)" class="btn btn-outline-primary">
                    <i class="bi bi-chevron-left"></i> @(currentYear - 1)
                </a>
                <button class="btn btn-primary" disabled>@currentYear</button>
                <a asp-action="MonthlyTrends" asp-route-year="@(currentYear + 1)" class="btn btn-outline-primary">
                    @(currentYear + 1) <i class="bi bi-chevron-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5>Monthly Application Statistics - @currentYear</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.MonthlyData != null && ViewBag.MonthlyData.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Month</th>
                                        <th>Total</th>
                                        <th>Pending</th>
                                        <th>Approved</th>
                                        <th>Rejected</th>
                                        <th>Under Review</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var month in ViewBag.MonthlyData)
                                    {
                                        <tr>
                                            <td><strong>@month.Month</strong></td>
                                            <td><span class="badge bg-primary">@month.Total</span></td>
                                            <td><span class="badge bg-warning text-dark">@month.Pending</span></td>
                                            <td><span class="badge bg-success">@month.Approved</span></td>
                                            <td><span class="badge bg-danger">@month.Rejected</span></td>
                                            <td><span class="badge bg-info">@month.UnderReview</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> No data available for @currentYear
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
