@model WelfareLink.Models.Resource

@{
    ViewData["Title"] = "Edit Resource";
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-pencil-square"></i> Edit Resource</h1>
        <p style="margin: 0; color: #64748b;">Update resource allocation details and status.</p>
    </div>
    <a asp-action="ManageResources" asp-route-programId="@Model.ProgramID" class="btn-modern btn-secondary-modern">
        <i class="bi bi-arrow-left"></i> Back to Resources
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center" role="alert">
        <i class="bi bi-check-circle-fill me-2" style="font-size: 1.5rem;"></i>
        <div>@TempData["SuccessMessage"]</div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2" style="font-size: 1.5rem;"></i>
        <div>@TempData["ErrorMessage"]</div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="content-card">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ResourceID" />
        <input type="hidden" asp-for="ProgramID" />

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                <h5><i class="bi bi-exclamation-triangle-fill"></i> Validation Errors:</h5>
                <div asp-validation-summary="All" class="text-danger"></div>
            </div>
        }

        <div class="row g-4">
            <div class="col-12">
                <div class="detail-item" style="background: linear-gradient(135deg, #e0f2fe 0%, #dbeafe 100%);">
                    <label>Programme</label>
                    <p style="font-size: 1.1rem; margin-top: 0.5rem;">
                        <strong>@ViewBag.ProgramTitle</strong>
                    </p>
                    <small style="color: #64748b; font-size: 0.85rem; display: block; margin-top: 0.5rem;">
                        <i class="bi bi-info-circle"></i> Programme cannot be changed after resource creation
                    </small>
                </div>
            </div>

            <div class="col-md-6">
                <div class="form-floating-modern">
                    <label asp-for="Type" class="form-label-modern">Resource Type</label>
                    <select asp-for="Type" asp-items="ViewBag.ResourceTypes" class="form-select">
                        <option value="">-- Select Type --</option>
                    </select>
                    <span asp-validation-for="Type" class="text-danger"></span>
                </div>
            </div>

            <div class="col-md-6">
                <div class="form-floating-modern">
                    <label asp-for="Quantity" class="form-label-modern">Quantity / Amount (₹)</label>
                    <input asp-for="Quantity" type="number" class="form-control" step="0.01" placeholder="0.00" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>
            </div>

            <div class="col-12">
                <div class="form-floating-modern">
                    <label asp-for="Status" class="form-label-modern">Resource Status</label>
                    <select asp-for="Status" asp-items="ViewBag.ResourceStatuses" class="form-select">
                        <option value="">-- Select Status --</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                    <div style="margin-top: 0.75rem; padding: 0.75rem; background: #f8fafc; border-radius: 8px; font-size: 0.9rem; color: #64748b;">
                        <i class="bi bi-info-circle text-primary"></i>
                        <strong>Available:</strong> Resource is ready to use | 
                        <strong>Reserved:</strong> Resource is allocated | 
                        <strong>Depleted:</strong> Resource has been consumed
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4 pt-3" style="border-top: 2px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
            <a asp-action="ManageResources" asp-route-programId="@Model.ProgramID" class="btn-modern btn-secondary-modern">
                <i class="bi bi-x-circle"></i> Cancel
            </a>
            <button type="submit" class="btn-modern btn-primary-modern">
                <i class="bi bi-check-circle"></i> Update Resource
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

