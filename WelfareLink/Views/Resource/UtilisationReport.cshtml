@model IEnumerable<WelfareLink.ViewModels.ResourceUtilisationViewModel>

@{
    ViewData["Title"] = "Resource Utilisation Report";
}

<div class="container-fluid mt-4" style="padding-bottom: 40px;">
    <div class="row mb-4">
        <div class="col-md-10">
            <h2><i class="bi bi-file-earmark-bar-graph"></i> Resource Utilisation Report</h2>
            <p class="text-muted">Detailed breakdown of resource consumption per programme</p>
        </div>
        <div class="col-md-2 text-end">
            <button onclick="window.print()" class="btn btn-outline-secondary">
                <i class="bi bi-printer"></i> Print Report
            </button>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5>Resource Utilisation Summary</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Resource ID</th>
                                    <th>Programme</th>
                                    <th>Type</th>
                                    <th>Initial Quantity</th>
                                    <th>Used</th>
                                    <th>Remaining</th>
                                    <th>Utilisation %</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.ResourceID</td>
                                        <td>
                                            <strong>@item.ProgramTitle</strong>
                                            <br><small class="text-muted">ID: @item.ProgramID</small>
                                        </td>
                                        <td>
                                            @if (item.Type == "Funds")
                                            {
                                                <span class="badge bg-success"><i class="bi bi-cash"></i> @item.Type</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info"><i class="bi bi-box"></i> @item.Type</span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.Type == "Funds")
                                            {
                                                <text>₹@item.InitialQuantity.ToString("N2")</text>
                                            }
                                            else
                                            {
                                                @item.InitialQuantity.ToString("N2")
                                            }
                                        </td>
                                        <td class="text-warning">
                                            @if (item.Type == "Funds")
                                            {
                                                <text>₹@item.UsedQuantity.ToString("N2")</text>
                                            }
                                            else
                                            {
                                                @item.UsedQuantity.ToString("N2")
                                            }
                                        </td>
                                        <td class="text-success">
                                            @if (item.Type == "Funds")
                                            {
                                                <text>₹@item.RemainingQuantity.ToString("N2")</text>
                                            }
                                            else
                                            {
                                                @item.RemainingQuantity.ToString("N2")
                                            }
                                        </td>
                                        <td>
                                            <div class="progress" style="width: 100px; height: 20px;">
                                                <div class="progress-bar @(item.UtilisationPercentage >= 80 ? "bg-danger" : item.UtilisationPercentage >= 50 ? "bg-warning" : "bg-success")" 
                                                     style="width: @Math.Min(item.UtilisationPercentage, 100)%">
                                                    @item.UtilisationPercentage.ToString("F0")%
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            @if (item.Status == "Available")
                                            {
                                                <span class="badge bg-success">@item.Status</span>
                                            }
                                            else if (item.Status == "Depleted")
                                            {
                                                <span class="badge bg-danger">@item.Status</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">@item.Status</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (!Model.Any())
                    {
                        <div class="alert alert-info text-center">
                            <i class="bi bi-info-circle"></i> No resource utilisation data available.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4 mb-5">
        <div class="col-md-12 text-center">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Resource List
            </a>
            <a asp-controller="WelfareProgram" asp-action="Index" class="btn btn-outline-primary">
                <i class="bi bi-list"></i> Programme List
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        @@media print {
            .btn, .breadcrumb { display: none; }
        }
    </style>
}
