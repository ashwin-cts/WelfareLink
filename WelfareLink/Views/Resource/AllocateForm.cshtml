@model WelfareLink.Models.Resource

@{
    ViewData["Title"] = "Allocate Resources";
    Layout = "_LayoutPM";
    var programs = ViewBag.Programs as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
}

<header>
    <h1>Add Resource Allocation</h1>
    <p>Manage resources allocated to a programme.</p>
</header>

<div class="form-container">
    <form asp-action="AllocateForm" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="ResourceID" value="0" />

        <div class="form-grid">
            <div class="form-group full-width">
                <label asp-for="ProgramID">Select Programme</label>
                <select asp-for="ProgramID" asp-items="programs" onchange="this.form.submit()">
                    <option value="">-- Select Programme --</option>
                </select>
                <span asp-validation-for="ProgramID" class="text-danger"></span>
            </div>

            @if (ViewBag.ProgramBudget != null)
            {
                <div class="form-group full-width">
                    <div style="background: #f0f8ff; border-left: 4px solid #2980b9; padding: 15px; margin-bottom: 10px; border-radius: 4px;">
                        <h5 style="margin: 0 0 12px 0; color: #2c3e50; font-size: 1rem;">
                            <i class="bi bi-cash-stack"></i> Budget Information - @ViewBag.ProgramTitle
                        </h5>
                        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">
                            <div>
                                <div style="font-size: 0.85rem; color: #7f8c8d; margin-bottom: 4px;">Programme Budget</div>
                                <div style="font-size: 1.25rem; font-weight: 600; color: #2980b9;">₹@ViewBag.ProgramBudget.ToString("N2")</div>
                            </div>
                            <div>
                                <div style="font-size: 0.85rem; color: #7f8c8d; margin-bottom: 4px;">Already Allocated</div>
                                <div style="font-size: 1.25rem; font-weight: 600; color: #e67e22;">₹@ViewBag.AllocatedFunds.ToString("N2")</div>
                            </div>
                            <div>
                                <div style="font-size: 0.85rem; color: #7f8c8d; margin-bottom: 4px;">Remaining Budget</div>
                                <div style="font-size: 1.25rem; font-weight: 600; color: @(ViewBag.RemainingBudget > 0 ? "#27ae60" : "#e74c3c");">
                                    ₹@ViewBag.RemainingBudget.ToString("N2")
                                </div>
                            </div>
                        </div>
                        @if (ViewBag.RemainingBudget <= 0)
                        {
                            <div style="margin-top: 12px; padding: 10px; background: #ffe6e6; border-radius: 4px; color: #c0392b; font-size: 0.9rem;">
                                <i class="bi bi-exclamation-triangle-fill"></i> <strong>Warning:</strong> No budget remaining. Increase programme budget before allocating more funds.
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="form-group">
                <label asp-for="Type">Resource Type</label>
                <select asp-for="Type">
                    <option value="">-- Select Type --</option>
                    <option value="Funds">Funds</option>
                    <option value="Materials">Materials</option>
                </select>
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Quantity">Quantity / Amount</label>
                <input asp-for="Quantity" type="number" step="0.01" placeholder="0.00" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
        </div>

        <div style="margin-top: 25px; padding-top: 15px; border-top: 1px solid #eee; display: flex; justify-content: space-between; align-items: center;">
            <span style="font-size: 0.9rem; color: #7f8c8d;">* Resource will be created with "Available" status.</span>
            <div>
                <button type="reset" class="btn btn-secondary">Clear</button>
                <button type="submit" class="btn btn-primary">Allocate Resource</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
