@model WelfareLink.Models.Resource

@{
    ViewData["Title"] = "Resource Details";
    Layout = "_LayoutPM";
}

<div class="container mt-4" style="padding-bottom: 40px;">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h4><i class="bi bi-info-circle"></i> Resource Details</h4>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Resource ID:</dt>
                        <dd class="col-sm-8">@Model.ResourceID</dd>

                        <dt class="col-sm-4">Programme:</dt>
                        <dd class="col-sm-8">
                            <strong>@Model.Program?.Title</strong>
                            <br><small class="text-muted">Programme ID: @Model.ProgramID</small>
                        </dd>

                        <dt class="col-sm-4">Resource Type:</dt>
                        <dd class="col-sm-8">
                            @if (Model.Type == "Funds")
                            {
                                <span class="badge bg-success"><i class="bi bi-cash"></i> @Model.Type</span>
                            }
                            else
                            {
                                <span class="badge bg-info"><i class="bi bi-box"></i> @Model.Type</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Quantity:</dt>
                        <dd class="col-sm-8">
                            @if (Model.Type == "Funds")
                            {
                                <h4 class="text-success">₹@Model.Quantity.ToString("N2")</h4>
                            }
                            else
                            {
                                <h4>@Model.Quantity.ToString("N2")</h4>
                            }
                        </dd>

                        <dt class="col-sm-4">Status:</dt>
                        <dd class="col-sm-8">
                            @if (Model.Status == "Available")
                            {
                                <span class="badge bg-success">@Model.Status</span>
                            }
                            else if (Model.Status == "Depleted")
                            {
                                <span class="badge bg-danger">@Model.Status</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">@Model.Status</span>
                            }
                        </dd>
                    </dl>

                    <div class="mt-4">
                        <a asp-action="Edit" asp-route-id="@Model.ResourceID" class="btn btn-primary">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <a asp-action="ManageResources" asp-route-programId="@Model.ProgramID" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Back to Resources
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
