@model IEnumerable<WelfareLink.Models.Resource>

@{
    ViewData["Title"] = "Manage Resources - " + ViewBag.ProgramTitle;
    var program = ViewBag.Program as WelfareLink.Models.WelfareProgram;
    var totalAllocated = ViewBag.TotalAllocated ?? 0m;
    var remainingBudget = ViewBag.RemainingBudget ?? 0m;
    var utilisationPercentage = ViewBag.UtilisationPercentage ?? 0m;
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-box-seam"></i> Resource Management</h1>
        <p style="margin: 0; color: #64748b;">@ViewBag.ProgramTitle</p>
    </div>
    <div style="display: flex; align-items: center; gap: 1rem;">
        <a asp-action="AllocateForm" asp-route-programId="@program?.ProgramID" class="btn-modern btn-success-modern" 
           style="padding: 0.85rem 1.5rem; font-size: 1.05rem; font-weight: 600;">
            <i class="bi bi-plus-circle" style="font-size: 1.2rem;"></i> Allocate New Resource
        </a>
        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <a asp-action="Index" class="btn-modern btn-secondary-modern" 
               style="padding: 0.5rem 1rem; font-size: 0.875rem;">
                <i class="bi bi-arrow-left"></i> Back to All Resources
            </a>
            <a asp-controller="WelfareProgram" asp-action="Details" asp-route-id="@program?.ProgramID" class="btn-modern btn-secondary-modern" 
               style="padding: 0.5rem 1rem; font-size: 0.875rem;">
                <i class="bi bi-arrow-left"></i> Back to Programme
            </a>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Budget KPI Cards -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="content-card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
            <div style="display: flex; align-items: center; gap: 1rem;">
                <i class="bi bi-cash-stack" style="font-size: 2.5rem; opacity: 0.8;"></i>
                <div>
                    <h6 style="margin: 0; opacity: 0.9; font-weight: 500; font-size: 0.85rem;">Total Budget</h6>
                    <h3 style="margin: 0.3rem 0 0 0; font-weight: 700;">₹@ViewBag.ProgramBudget.ToString("N2")</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="content-card" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white;">
            <div style="display: flex; align-items: center; gap: 1rem;">
                <i class="bi bi-pie-chart-fill" style="font-size: 2.5rem; opacity: 0.8;"></i>
                <div>
                    <h6 style="margin: 0; opacity: 0.9; font-weight: 500; font-size: 0.85rem;">Allocated</h6>
                    <h3 style="margin: 0.3rem 0 0 0; font-weight: 700;">₹@totalAllocated.ToString("N2")</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="content-card" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white;">
            <div style="display: flex; align-items: center; gap: 1rem;">
                <i class="bi bi-piggy-bank-fill" style="font-size: 2.5rem; opacity: 0.8;"></i>
                <div>
                    <h6 style="margin: 0; opacity: 0.9; font-weight: 500; font-size: 0.85rem;">Remaining</h6>
                    <h3 style="margin: 0.3rem 0 0 0; font-weight: 700; @(remainingBudget < 0 ? "color: #fecaca;" : "")">₹@remainingBudget.ToString("N2")</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="content-card" style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); color: white;">
            <div style="display: flex; align-items: center; gap: 1rem;">
                <i class="bi bi-graph-up-arrow" style="font-size: 2.5rem; opacity: 0.8;"></i>
                <div>
                    <h6 style="margin: 0; opacity: 0.9; font-weight: 500; font-size: 0.85rem;">Utilisation</h6>
                    <h3 style="margin: 0.3rem 0 0 0; font-weight: 700;">@utilisationPercentage.ToString("F1")%</h3>
                </div>
            </div>
        </div>
    </div>
</div>

@if (utilisationPercentage >= 80)
{
    <div class="alert alert-danger d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-3" style="font-size: 1.5rem;"></i>
        <div>
            <strong>Warning!</strong> Budget utilisation has reached critical level (≥80%).
        </div>
    </div>
}

<!-- Resources Table -->
<div class="content-card">
    <h2 style="color: #1e3c72; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 10px;">
        <i class="bi bi-list-ul"></i> Allocated Resources
    </h2>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-modern">
                <thead>
                    <tr>
                        <th>Resource ID</th>
                        <th>Type</th>
                        <th>Quantity</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var resource in Model)
                    {
                        <tr>
                            <td><strong>RES-@resource.ResourceID</strong></td>
                            <td>
                                @if (resource.Type == "Funds")
                                {
                                    <span class="status-badge status-completed">
                                        <i class="bi bi-cash"></i> @resource.Type
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge status-allocated">
                                        <i class="bi bi-box"></i> @resource.Type
                                    </span>
                                }
                            </td>
                            <td>
                                @if (resource.Type == "Funds")
                                {
                                    <strong style="color: #10b981;">₹@resource.Quantity.ToString("N2")</strong>
                                }
                                else
                                {
                                    <strong>@resource.Quantity.ToString("N2") units</strong>
                                }
                            </td>
                            <td>
                                @if (resource.Status == "Available")
                                {
                                    <span class="status-badge status-completed">
                                        <i class="bi bi-check-circle-fill"></i> @resource.Status
                                    </span>
                                }
                                else if (resource.Status == "Depleted")
                                {
                                    <span class="status-badge status-failed">
                                        <i class="bi bi-x-circle-fill"></i> @resource.Status
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge status-pending">
                                        <i class="bi bi-clock-fill"></i> @resource.Status
                                    </span>
                                }
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a asp-action="Edit" asp-route-id="@resource.ResourceID" class="btn-modern btn-warning-modern btn-sm">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr style="background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);">
                        <td colspan="2"><strong style="color: #1e3c72;">Total Funds Allocated:</strong></td>
                        <td colspan="3">
                            <strong style="color: #10b981; font-size: 1.1rem;">₹@Model.Where(r => r.Type == "Funds").Sum(r => r.Quantity).ToString("N2")</strong>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox" style="font-size: 4rem; color: #cbd5e1;"></i>
            <h4 class="text-muted mt-3">No Resources Allocated Yet</h4>
            <p class="text-muted">Start by allocating your first resource to this programme.</p>
            <a asp-action="AllocateForm" asp-route-programId="@program?.ProgramID" class="btn-modern btn-primary-modern mt-3">
                <i class="bi bi-plus-circle"></i> Allocate First Resource
            </a>
        </div>
    }
</div>
