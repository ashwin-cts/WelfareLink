@model IEnumerable<WelfareLink.Models.Resource>

@{
    ViewData["Title"] = "Resource List";
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-box-seam"></i> Resource Management</h1>
        <p style="margin: 0; color: #64748b;">View and manage all allocated resources across programmes.</p>
    </div>
    <div class="action-buttons">
        <a asp-action="AllocateForm" class="btn-modern btn-primary-modern">
            <i class="bi bi-plus-circle"></i> Allocate Resource
        </a>
        <a asp-action="UtilisationReport" class="btn-modern btn-info-modern">
            <i class="bi bi-file-earmark-bar-graph"></i> Utilisation Report
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="content-card">
    <div class="table-responsive">
        <table class="table table-modern">
            <thead>
                <tr>
                    <th>Resource ID</th>
                    <th>Programme</th>
                    <th>Type</th>
                    <th>Quantity</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>RES-@item.ResourceID</strong></td>
                        <td>
                            <div>
                                <strong style="color: #1e3c72;">@item.Program?.Title</strong>
                                <br><small class="text-muted">PRG-@item.ProgramID</small>
                            </div>
                        </td>
                        <td>
                            @if (item.Type == "Funds")
                            {
                                <span class="status-badge status-completed">
                                    <i class="bi bi-cash"></i> @item.Type
                                </span>
                            }
                            else
                            {
                                <span class="status-badge status-allocated">
                                    <i class="bi bi-box"></i> @item.Type
                                </span>
                            }
                        </td>
                        <td>
                            @if (item.Type == "Funds")
                            {
                                <strong style="color: #10b981;">₹@item.Quantity.ToString("N2")</strong>
                            }
                            else
                            {
                                <strong>@item.Quantity.ToString("N2") units</strong>
                            }
                        </td>
                        <td>
                            @if (item.Status == "Available")
                            {
                                <span class="status-badge status-completed">
                                    <i class="bi bi-check-circle-fill"></i> @item.Status
                                </span>
                            }
                            else if (item.Status == "Depleted")
                            {
                                <span class="status-badge status-failed">
                                    <i class="bi bi-x-circle-fill"></i> @item.Status
                                </span>
                            }
                            else
                            {
                                <span class="status-badge status-pending">
                                    <i class="bi bi-clock-fill"></i> @item.Status
                                </span>
                            }
                        </td>
                        <td>
                            <div class="action-buttons">
                                <a asp-action="ManageResources" asp-route-programId="@item.ProgramID" class="btn-modern btn-info-modern btn-sm" title="View Programme Resources">
                                    <i class="bi bi-eye"></i> View
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.ResourceID" class="btn-modern btn-warning-modern btn-sm" title="Edit Resource">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center mt-4">
            <i class="bi bi-info-circle"></i> No resources allocated yet.
        </div>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
