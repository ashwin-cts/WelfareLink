@model IEnumerable<WelfareLink.Models.Resource>

@{
    ViewData["Title"] = "Resource List";
    Layout = "_LayoutPM";
}

<div class="container mt-4" style="padding-bottom: 40px;">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2><i class="bi bi-box-seam"></i> Resource Management</h2>
            <p class="text-muted">View and manage all allocated resources</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Allocate Resource
            </a>
            <a asp-action="UtilisationReport" class="btn btn-info">
                <i class="bi bi-file-earmark-bar-graph"></i> Utilisation Report
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Resource ID</th>
                            <th>Programme</th>
                            <th>Type</th>
                            <th>Quantity</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ResourceID</td>
                                <td>
                                    <strong>@item.Program?.Title</strong>
                                    <br><small class="text-muted">ID: @item.ProgramID</small>
                                </td>
                                <td>
                                    @if (item.Type == "Funds")
                                    {
                                        <span class="badge bg-success"><i class="bi bi-cash"></i> @item.Type</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info"><i class="bi bi-box"></i> @item.Type</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Type == "Funds")
                                    {
                                        <strong>₹@item.Quantity.ToString("N2")</strong>
                                    }
                                    else
                                    {
                                        <strong>@item.Quantity.ToString("N2")</strong>
                                    }
                                </td>
                                <td>
                                    @if (item.Status == "Available")
                                    {
                                        <span class="badge bg-success">@item.Status</span>
                                    }
                                    else if (item.Status == "Depleted")
                                    {
                                        <span class="badge bg-danger">@item.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">@item.Status</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Details" asp-route-id="@item.ResourceID" class="btn btn-outline-info" title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.ResourceID" class="btn btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center mt-4">
            <i class="bi bi-info-circle"></i> No resources allocated yet.
        </div>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
