@model WelfareLink.Models.ComplainceRecord
@{
    ViewData["Title"] = "Edit Compliance Record";
}

<h1>Edit Compliance Record</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="ComplainceID" />
    <div class="form-group">
        <label asp-for="EntityID"></label>
        <input asp-for="EntityID" class="form-control" />
        <span asp-validation-for="EntityID" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Type"></label>
        <input asp-for="Type" class="form-control" />
        <span asp-validation-for="Type" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Result"></label>
        <input asp-for="Result" class="form-control" />
        <span asp-validation-for="Result" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Notes"></label>
        <textarea asp-for="Notes" class="form-control"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-controller="ComplainceRecords" asp-action="Index" class="btn btn-secondary">Back to list</a>
</form>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}