@model WelfareLink.Models.ComplainceRecord
@{
    ViewData["Title"] = "Delete Compliance Record";
}

<h1>Delete Compliance Record</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">ID</dt>
        <dd class="col-sm-10">@Model.ComplainceID</dd>

        <dt class="col-sm-2">Entity ID</dt>
        <dd class="col-sm-10">@Model.EntityID</dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-controller="ComplainceRecords" asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>