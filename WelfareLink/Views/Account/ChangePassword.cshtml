@model WelfareLink.Controllers.ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
    var userName = Context.Session.GetString("Username") ?? Context.Session.GetString("FullName");
    var userRole = Context.Session.GetString("UserRole");
    var userId   = Context.Session.GetInt32("UserId");
}

<div class="page-header">
    <h1><i class="bi bi-lock-fill"></i> Change Password</h1>
    <a asp-action="EditProfile" class="btn-modern btn-secondary-modern">
        <i class="bi bi-arrow-left"></i> Back to Profile
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-4 justify-content-center">
    <!-- Account Info sidebar -->
    <div class="col-md-4">
        <div class="content-card">
            <h5 class="mb-4"><i class="bi bi-person-badge text-primary"></i> Account Info</h5>
            <div class="d-flex flex-column gap-3">
                <div class="detail-item">
                    <label>User ID</label>
                    <p><span class="badge bg-secondary">#@userId</span></p>
                </div>
                <div class="detail-item">
                    <label>Username</label>
                    <p><strong>@userName</strong></p>
                </div>
                <div class="detail-item">
                    <label>Role</label>
                    <p>
                        <span class="status-badge status-fully-disbursed">
                            <i class="bi bi-shield-check"></i> @userRole
                        </span>
                    </p>
                </div>
            </div>

            <div class="alert alert-warning mt-4 mb-0">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <strong>Security Tip:</strong> Use a strong password with letters, numbers, and symbols.
            </div>
        </div>
    </div>

    <!-- Change Password Form -->
    <div class="col-md-5">
        <div class="content-card">
            <h5 class="mb-4"><i class="bi bi-key-fill text-warning"></i> Update Password</h5>

            <form asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-4">
                    <label asp-for="CurrentPassword" class="form-label-modern"></label>
                    <div class="input-group">
                        <span class="input-group-text" style="border-radius:12px 0 0 12px; border:2px solid #e2e8f0; border-right:none;">
                            <i class="bi bi-lock text-muted"></i>
                        </span>
                        <input asp-for="CurrentPassword" class="form-control" type="password"
                               placeholder="Enter your current password"
                               style="border-radius:0 12px 12px 0; border:2px solid #e2e8f0; border-left:none;" />
                    </div>
                    <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                </div>

                <hr class="my-3" />

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label-modern"></label>
                    <div class="input-group">
                        <span class="input-group-text" style="border-radius:12px 0 0 12px; border:2px solid #e2e8f0; border-right:none;">
                            <i class="bi bi-lock-fill text-primary"></i>
                        </span>
                        <input asp-for="NewPassword" class="form-control" type="password"
                               placeholder="Enter new password (min 6 characters)"
                               style="border-radius:0 12px 12px 0; border:2px solid #e2e8f0; border-left:none;" />
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label-modern"></label>
                    <div class="input-group">
                        <span class="input-group-text" style="border-radius:12px 0 0 12px; border:2px solid #e2e8f0; border-right:none;">
                            <i class="bi bi-lock-fill text-success"></i>
                        </span>
                        <input asp-for="ConfirmPassword" class="form-control" type="password"
                               placeholder="Re-enter new password"
                               style="border-radius:0 12px 12px 0; border:2px solid #e2e8f0; border-left:none;" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-3">
                    <button type="submit" class="btn-modern btn-success-modern">
                        <i class="bi bi-check-circle"></i> Update Password
                    </button>
                    <a asp-action="EditProfile" class="btn-modern btn-secondary-modern">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
