@model IEnumerable<WelfareLink.Models.WelfareProgram>

@{
    ViewData["Title"] = "PM Dashboard";

    // Get all resources from ViewBag
    var allResources = ViewBag.AllResources as IEnumerable<WelfareLink.Models.Resource> ?? Enumerable.Empty<WelfareLink.Models.Resource>();

    // Calculate total budget across all programmes
    var totalBudget = Model.Sum(p => p.Budget);

    // Calculate allocated budget from all "Funds" type resources
    var allocatedBudget = allResources
        .Where(r => r.Type.Equals("Funds", StringComparison.OrdinalIgnoreCase))
        .Sum(r => r.Quantity);

    // Calculate remaining budget
    var remainingBudget = totalBudget - allocatedBudget;
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-speedometer2"></i> Program Dashboard</h1>
        <p style="margin: 0; color: #64748b;">Overview of active welfare programmes and overall budget.</p>
    </div>
    <a asp-action="Manage" class="btn-modern btn-primary-modern">
        <i class="bi bi-plus-circle"></i> Add Programme
    </a>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="content-card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
            <div style="display: flex; align-items: center; gap: 1rem;">
                <i class="bi bi-cash-stack" style="font-size: 3rem; opacity: 0.8;"></i>
                <div>
                    <h6 style="margin: 0; opacity: 0.9; font-weight: 500;">Total Budget</h6>
                    <h2 style="margin: 0.5rem 0 0 0; font-weight: 700;">₹@totalBudget.ToString("N0")</h2>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="content-card" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white;">
            <div style="display: flex; align-items: center; gap: 1rem;">
                <i class="bi bi-pie-chart-fill" style="font-size: 3rem; opacity: 0.8;"></i>
                <div>
                    <h6 style="margin: 0; opacity: 0.9; font-weight: 500;">Allocated</h6>
                    <h2 style="margin: 0.5rem 0 0 0; font-weight: 700;">₹@allocatedBudget.ToString("N0")</h2>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="content-card" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white;">
            <div style="display: flex; align-items: center; gap: 1rem;">
                <i class="bi bi-piggy-bank-fill" style="font-size: 3rem; opacity: 0.8;"></i>
                <div>
                    <h6 style="margin: 0; opacity: 0.9; font-weight: 500;">Remaining</h6>
                    <h2 style="margin: 0.5rem 0 0 0; font-weight: 700;">₹@remainingBudget.ToString("N0")</h2>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="content-card">
    <h2 style="color: #1e3c72; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 10px;">
        <i class="bi bi-activity"></i> Active Programmes
    </h2>
    <div class="table-responsive">
        <table class="table table-modern">
            <thead>
                <tr>
                    <th>Program ID</th>
                    <th>Title</th>
                    <th>Budget</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var program in Model.Where(p => p.Status == "Active"))
                {
                    <tr>
                        <td><strong>PRG-@program.ProgramID</strong></td>
                        <td>@program.Title</td>
                        <td><strong>₹@program.Budget.ToString("N0")</strong></td>
                        <td>
                            <span class="status-badge status-completed">
                                <i class="bi bi-check-circle-fill"></i> @program.Status
                            </span>
                        </td>
                        <td>
                            <div class="action-buttons">
                                <a asp-action="Edit" asp-route-id="@program.ProgramID" class="btn-modern btn-warning-modern btn-sm">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a asp-action="Details" asp-route-id="@program.ProgramID" class="btn-modern btn-info-modern btn-sm">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any(p => p.Status == "Active"))
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox" style="font-size: 3rem; color: #cbd5e1;"></i>
                <p class="text-muted mt-3">No active programmes found.</p>
            </div>
        }
    </div>
</div>
