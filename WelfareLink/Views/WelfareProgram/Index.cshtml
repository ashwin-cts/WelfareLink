@model IEnumerable<WelfareLink.Models.WelfareProgram>

@{
    ViewData["Title"] = "Programme List";
    Layout = "_LayoutPM";
}

<header>
    <h1>Programme List</h1>
    <p>Search and manage all welfare programmes.</p>
</header>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="search-container">
    <input type="text" id="searchInput" placeholder="Search by Program ID or Title..." onkeyup="searchTable()">
    <button type="button">Search</button>
</div>

<div class="table-container">
    <table id="programTable">
        <thead>
            <tr>
                <th>ProgramID</th>
                <th>Title</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Budget</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>PRG-@item.ProgramID</td>
                    <td>@item.Title</td>
                    <td>@item.StartDate.ToString("yyyy-MM-dd")</td>
                    <td>@item.EndDate.ToString("yyyy-MM-dd")</td>
                    <td>₹@item.Budget.ToString("N0")</td>
                    <td>
                        @if (item.Status == "Active")
                        {
                            <span class="badge active">@item.Status</span>
                        }
                        else if (item.Status == "Completed")
                        {
                            <span class="badge completed">@item.Status</span>
                        }
                        else
                        {
                            <span class="badge warning">@item.Status</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.ProgramID">Edit</a> | 
                        <a asp-action="Details" asp-route-id="@item.ProgramID">View</a> | 
                        <a asp-controller="Resource" asp-action="ManageResources" asp-route-programId="@item.ProgramID">Allocate</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <p style="text-align: center; color: #7f8c8d; padding: 20px;">No programmes found.</p>
    }
</div>

@section Scripts {
    <script>
        function searchTable() {
            const input = document.getElementById("searchInput");
            const filter = input.value.toUpperCase();
            const table = document.getElementById("programTable");
            const tr = table.getElementsByTagName("tr");

            for (let i = 1; i < tr.length; i++) {
                const tdId = tr[i].getElementsByTagName("td")[0];
                const tdTitle = tr[i].getElementsByTagName("td")[1];

                if (tdId || tdTitle) {
                    const txtId = tdId.textContent || tdId.innerText;
                    const txtTitle = tdTitle.textContent || tdTitle.innerText;

                    if (txtId.toUpperCase().indexOf(filter) > -1 || txtTitle.toUpperCase().indexOf(filter) > -1) {
                        tr[i].style.display = "";
                    } else {
                        tr[i].style.display = "none";
                    }
                }
            }
        }
    </script>
}
