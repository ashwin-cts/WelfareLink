@model IEnumerable<WelfareLink.Models.WelfareProgram>

@{
    ViewData["Title"] = "Programme List";
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-diagram-3"></i> Programme List</h1>
        <p style="margin: 0; color: #64748b;">Search and manage all welfare programmes.</p>
    </div>
    <a asp-action="Manage" class="btn-modern btn-primary-modern">
        <i class="bi bi-plus-circle"></i> Add New Programme
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="content-card">
    <div class="mb-4">
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" id="searchInput" class="form-control" placeholder="Search by Program ID or Title..." onkeyup="searchTable()">
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-modern" id="programTable">
            <thead>
                <tr>
                    <th>Program ID</th>
                    <th>Title</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Budget</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>PRG-@item.ProgramID</strong></td>
                        <td>@item.Title</td>
                        <td>@item.StartDate.ToString("MMM dd, yyyy")</td>
                        <td>@item.EndDate.ToString("MMM dd, yyyy")</td>
                        <td><strong>₹@item.Budget.ToString("N0")</strong></td>
                        <td>
                            @if (item.Status == "Active")
                            {
                                <span class="status-badge status-completed">
                                    <i class="bi bi-check-circle-fill"></i> @item.Status
                                </span>
                            }
                            else if (item.Status == "Completed")
                            {
                                <span class="status-badge status-fully-disbursed">
                                    <i class="bi bi-flag-fill"></i> @item.Status
                                </span>
                            }
                            else
                            {
                                <span class="status-badge status-pending">
                                    <i class="bi bi-clock-fill"></i> @item.Status
                                </span>
                            }
                        </td>
                        <td>
                            <div class="action-buttons">
                                <a asp-action="Edit" asp-route-id="@item.ProgramID" class="btn-modern btn-warning-modern btn-sm">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a asp-action="Details" asp-route-id="@item.ProgramID" class="btn-modern btn-info-modern btn-sm">
                                    <i class="bi bi-eye"></i> View
                                </a>
                                <a asp-controller="Resource" asp-action="ManageResources" asp-route-programId="@item.ProgramID" class="btn-modern btn-success-modern btn-sm">
                                    <i class="bi bi-box-seam"></i> Allocate
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox" style="font-size: 3rem; color: #cbd5e1;"></i>
                <p class="text-muted mt-3">No programmes found.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function searchTable() {
            const input = document.getElementById("searchInput");
            const filter = input.value.toUpperCase();
            const table = document.getElementById("programTable");
            const tr = table.getElementsByTagName("tr");

            for (let i = 1; i < tr.length; i++) {
                const tdId = tr[i].getElementsByTagName("td")[0];
                const tdTitle = tr[i].getElementsByTagName("td")[1];

                if (tdId || tdTitle) {
                    const txtId = tdId.textContent || tdId.innerText;
                    const txtTitle = tdTitle.textContent || tdTitle.innerText;

                    if (txtId.toUpperCase().indexOf(filter) > -1 || txtTitle.toUpperCase().indexOf(filter) > -1) {
                        tr[i].style.display = "";
                    } else {
                        tr[i].style.display = "none";
                    }
                }
            }
        }
    </script>
}
