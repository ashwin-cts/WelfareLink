@model WelfareLink.Controllers.DocumentStatusViewModel
@{
    ViewData["Title"] = "Document Status";
}

<div class="container mt-4">
    <h1 class="mb-4">Document Status</h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="btn-group" role="group">
                <a asp-controller="CitizenDocument" asp-action="DocumentStatus" class="btn @(string.IsNullOrEmpty(Model.FilterStatus) ? "btn-primary" : "btn-outline-primary")">All</a>
                <a asp-controller="CitizenDocument" asp-action="DocumentStatus" asp-route-status="Pending" class="btn @(Model.FilterStatus == "Pending" ? "btn-warning" : "btn-outline-warning")">Pending</a>
                <a asp-controller="CitizenDocument" asp-action="DocumentStatus" asp-route-status="Approved" class="btn @(Model.FilterStatus == "Approved" ? "btn-success" : "btn-outline-success")">Approved</a>
                <a asp-controller="CitizenDocument" asp-action="DocumentStatus" asp-route-status="Rejected" class="btn @(Model.FilterStatus == "Rejected" ? "btn-danger" : "btn-outline-danger")">Rejected</a>
            </div>
            <a asp-controller="CitizenDocument" asp-action="UploadDocument" class="btn btn-primary float-end">
                <i class="bi bi-plus-circle"></i> Upload New Document
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            @if (Model.Documents.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Document ID</th>
                                <th>Document Type</th>
                                <th>Upload Date</th>
                                <th>Verification Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doc in Model.Documents)
                            {
                                <tr>
                                    <td>@doc.DocumentID</td>
                                    <td>@doc.DocType</td>
                                    <td>@doc.UploadedDate.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        @if (doc.VerificationStatus == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="bi bi-clock"></i> @doc.VerificationStatus
                                            </span>
                                        }
                                        else if (doc.VerificationStatus == "Approved")
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle"></i> @doc.VerificationStatus
                                            </span>
                                        }
                                        else if (doc.VerificationStatus == "Rejected")
                                        {
                                            <span class="badge bg-danger">
                                                <i class="bi bi-x-circle"></i> @doc.VerificationStatus
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@doc.VerificationStatus</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(doc.FileURI))
                                        {
                                            <a href="@doc.FileURI" target="_blank" class="btn btn-sm btn-info" title="View Document">
                                                <i class="bi bi-eye"></i> View
                                            </a>
                                        }
                                        @if (doc.VerificationStatus == "Pending" || doc.VerificationStatus == "Rejected")
                                        {
                                            <form asp-controller="CitizenDocument" asp-action="Delete" asp-route-documentId="@doc.DocumentID" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-danger" title="Delete Document" 
                                                        onclick="return confirm('Are you sure you want to delete this document?');">
                                                    <i class="bi bi-trash"></i> Delete
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-file-earmark-x" style="font-size: 3rem; color: #ccc;"></i>
                    <p class="text-muted mt-3">No documents found.</p>
                    <a asp-controller="CitizenDocument" asp-action="UploadDocument" class="btn btn-primary">Upload Your First Document</a>
                </div>
            }
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Citizen" asp-action="Dashboard" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>