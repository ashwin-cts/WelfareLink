@model WelfareLink.Models.Audit
@{
    ViewData["Title"] = "Audit Details";
}

<h1>Audit Details</h1>

<div>
    <dl class="row">
        <dt class="col-sm-2">Audit ID</dt>
        <dd class="col-sm-10">@Model.AuditID</dd>

        <dt class="col-sm-2">Officer ID</dt>
        <dd class="col-sm-10">@Model.OfficerID</dd>

        <dt class="col-sm-2">Scope</dt>
        <dd class="col-sm-10">@Model.Scope</dd>

        <dt class="col-sm-2">Findings</dt>
        <dd class="col-sm-10">@Model.Findings</dd>

        <dt class="col-sm-2">Date</dt>
        <dd class="col-sm-10">@Model.Date.ToString("yyyy-MM-dd HH:mm")</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.Status</dd>
    </dl>
</div>

<p>
    <a asp-controller="Audits" asp-action="Index" class="btn btn-secondary">Back to list</a>
</p>