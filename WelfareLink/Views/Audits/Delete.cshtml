@model WelfareLink.Models.Audit
@{
    ViewData["Title"] = "Delete Audit";
}

<h1>Delete Audit</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Audit ID</dt>
        <dd class="col-sm-10">@Model.AuditID</dd>

        <dt class="col-sm-2">Scope</dt>
        <dd class="col-sm-10">@Model.Scope</dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-controller="Audits" asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>