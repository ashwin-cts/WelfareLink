@model WelfareLink.Models.EligibilityCheck

@{
    ViewData["Title"] = "Perform Eligibility Check";
    var applicationId = Context.Request.Query["applicationId"].ToString();
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="display-4">@ViewData["Title"]</h1>
            <p class="lead">Record eligibility assessment results</p>
        </div>
    </div>

    @if (ViewBag.Application != null)
    {
        <div class="row mb-3">
            <div class="col-md-12">
                <div class="alert alert-info">
                    <h5><i class="bi bi-info-circle"></i> Application Information</h5>
                    <p><strong>Application ID:</strong> @ViewBag.Application.ApplicationID</p>
                    <p><strong>Submitted Date:</strong> @ViewBag.Application.SubmittedDate.ToString("dd MMMM yyyy")</p>
                    <p><strong>Current Status:</strong> <span class="badge bg-secondary">@ViewBag.Application.Status</span></p>
                </div>
            </div>
        </div>
    }

    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5>Eligibility Assessment Form</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        @if (!string.IsNullOrEmpty(applicationId))
                        {
                            <input type="hidden" name="applicationId" value="@applicationId" />
                            <input type="hidden" asp-for="ApplicationID" value="@applicationId" />
                        }
                        else
                        {
                            <div class="mb-3">
                                <label asp-for="ApplicationID" class="form-label"></label>
                                <input asp-for="ApplicationID" type="number" class="form-control" placeholder="Enter Application ID" required />
                                <span asp-validation-for="ApplicationID" class="text-danger"></span>
                            </div>
                        }

                        <div class="mb-3">
                            <label asp-for="OfficerID" class="form-label"></label>
                            <input asp-for="OfficerID" type="number" class="form-control" placeholder="Enter Officer ID" required />
                            <span asp-validation-for="OfficerID" class="text-danger"></span>
                            <small class="form-text text-muted">Enter the ID of the officer performing this check</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Result" class="form-label"></label>
                            <select asp-for="Result" class="form-select" required>
                                <option value="">Select Result...</option>
                                <option value="Eligible">Eligible</option>
                                <option value="Ineligible">Ineligible</option>
                            </select>
                            <span asp-validation-for="Result" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ResultCode" class="form-label"></label>
                            <input asp-for="ResultCode" class="form-control" placeholder="e.g., ELIG-001, INELIG-002" required />
                            <span asp-validation-for="ResultCode" class="text-danger"></span>
                            <small class="form-text text-muted">Enter a unique result code for tracking purposes</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="5" placeholder="Enter assessment notes, reasons, or additional comments..." required></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>

                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <strong>Important:</strong> This eligibility check will automatically update the application status.
                            <ul class="mb-0 mt-2">
                                <li><strong>Eligible</strong> will mark the application as <span class="badge bg-success">Approved</span></li>
                                <li><strong>Ineligible</strong> will mark the application as <span class="badge bg-danger">Rejected</span></li>
                            </ul>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-between mt-4">
                            @if (!string.IsNullOrEmpty(applicationId))
                            {
                                <a asp-controller="WelfareApplication" asp-action="Details" asp-route-id="@applicationId" class="btn btn-secondary">
                                    <i class="bi bi-arrow-left"></i> Cancel
                                </a>
                            }
                            else
                            {
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="bi bi-arrow-left"></i> Cancel
                                </a>
                            }
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Submit Eligibility Check
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
