@model WelfareLink.Models.EligibilityCheck

@{
    ViewData["Title"] = "Eligibility Check Details";
}

<div class="page-header">
    <h1>
        <i class="bi bi-clipboard-check"></i>
        Eligibility Check Details
    </h1>
    <p class="mb-0">Check ID: #@Model.CheckID</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-md-8">
        <!-- Application Information -->
        @if (Model.WelfareApplication != null)
        {
            <div class="content-card mb-3">
                <h4 class="mb-3"><i class="bi bi-file-earmark-text"></i> Application Information</h4>
                <div class="detail-grid">
                    <div class="detail-item">
                        <label>Application ID</label>
                        <p>
                            <a asp-controller="WelfareApplication" asp-action="Details" asp-route-id="@Model.ApplicationID"
                               class="badge bg-primary fs-6 text-decoration-none">
                                #@Model.ApplicationID
                            </a>
                        </p>
                    </div>
                    <div class="detail-item">
                        <label>Program</label>
                        <p>
                            @if (Model.WelfareApplication.Program != null)
                            {
                                <strong>@Model.WelfareApplication.Program.Title</strong>
                                <br /><small class="text-muted">ID: #@Model.WelfareApplication.ProgramID</small>
                            }
                            else
                            {
                                <span>Program #@Model.WelfareApplication.ProgramID</span>
                            }
                        </p>
                    </div>
                    <div class="detail-item">
                        <label>Submitted Date</label>
                        <p>@Model.WelfareApplication.SubmittedDate.ToString("dd MMMM yyyy")</p>
                    </div>
                    <div class="detail-item">
                        <label>Application Status</label>
                        <p>
                            @if (Model.WelfareApplication.Status == "Pending")
                            {
                                <span class="status-badge status-pending"><i class="bi bi-clock"></i> Pending</span>
                            }
                            else if (Model.WelfareApplication.Status == "Approved")
                            {
                                <span class="status-badge status-fully-disbursed"><i class="bi bi-check-circle"></i> Approved</span>
                            }
                            else if (Model.WelfareApplication.Status == "Rejected")
                            {
                                <span class="status-badge status-failed"><i class="bi bi-x-circle"></i> Rejected</span>
                            }
                            else
                            {
                                <span class="status-badge status-processing">@Model.WelfareApplication.Status</span>
                            }
                        </p>
                    </div>
                </div>
            </div>

            <!-- Citizen Information -->
            @if (Model.WelfareApplication.Citizen != null)
            {
                <div class="content-card mb-3">
                    <h4 class="mb-3"><i class="bi bi-person-badge"></i> Citizen Information</h4>
                    <div class="detail-grid">
                        <div class="detail-item">
                            <label>Citizen ID</label>
                            <p>#@Model.WelfareApplication.Citizen.CitizenId</p>
                        </div>
                        <div class="detail-item">
                            <label>Name</label>
                            <p><strong>@Model.WelfareApplication.Citizen.Name</strong></p>
                        </div>
                        <div class="detail-item">
                            <label>Date of Birth</label>
                            <p>@Model.WelfareApplication.Citizen.DateOfBirth.ToString("dd MMMM yyyy")</p>
                        </div>
                        <div class="detail-item">
                            <label>Contact Info</label>
                            <p>@Model.WelfareApplication.Citizen.ContactInfo</p>
                        </div>
                        <div class="detail-item" style="grid-column: span 2;">
                            <label>Address</label>
                            <p>@Model.WelfareApplication.Citizen.Address</p>
                        </div>
                        <div class="detail-item">
                            <label>Status</label>
                            <p>
                                @if (Model.WelfareApplication.Citizen.Status == "Active")
                                {
                                    <span class="status-badge status-fully-disbursed">Active</span>
                                }
                                else
                                {
                                    <span class="status-badge status-failed">@Model.WelfareApplication.Citizen.Status</span>
                                }
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Submitted Documents -->
                @if (Model.WelfareApplication.ApplicationDocuments != null && Model.WelfareApplication.ApplicationDocuments.Any())
                {
                    <div class="content-card mb-3">
                        <h4 class="mb-3">
                            <i class="bi bi-file-earmark-pdf"></i> Submitted Documents
                            <span class="badge bg-success ms-2" style="font-size:0.75rem;">Submitted with Application</span>
                        </h4>
                        <div class="table-responsive">
                            <table class="table table-modern">
                                <thead>
                                    <tr>
                                        <th>Document ID</th>
                                        <th>Document Name</th>
                                        <th>Document Type</th>
                                        <th>Uploaded Date</th>
                                        <th>Verification Status</th>
                                        <th>View</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var appDoc in Model.WelfareApplication.ApplicationDocuments)
                                    {
                                        var doc = appDoc.CitizenDocument;
                                        if (doc != null)
                                        {
                                            <tr>
                                                <td><span class="badge bg-secondary">#@doc.DocumentID</span></td>
                                                <td><strong>@(doc.DocumentName ?? "-")</strong></td>
                                                <td><strong>@doc.DocType</strong></td>
                                                <td>@doc.UploadedDate.ToString("dd/MM/yyyy")</td>
                                                <td>
                                                    @if (doc.VerificationStatus == "Approved")
                                                    {
                                                        <span class="status-badge status-fully-disbursed"><i class="bi bi-check-circle"></i> Approved</span>
                                                    }
                                                    else if (doc.VerificationStatus == "Pending")
                                                    {
                                                        <span class="status-badge status-pending"><i class="bi bi-clock"></i> Pending</span>
                                                    }
                                                    else if (doc.VerificationStatus == "Rejected")
                                                    {
                                                        <span class="status-badge status-failed"><i class="bi bi-x-circle"></i> Rejected</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="status-badge status-processing">@doc.VerificationStatus</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(doc.FileURI))
                                                    {
                                                        <a href="@doc.FileURI" target="_blank" class="btn-modern btn-info-modern btn-sm">
                                                            <i class="bi bi-eye"></i> View
                                                        </a>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted small">No file</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            }
        }

        <!-- Eligibility Assessment Information -->
        <div class="content-card mb-3">
            <h4 class="mb-3"><i class="bi bi-clipboard-data"></i> Eligibility Assessment</h4>
            <div class="detail-grid">
                <div class="detail-item">
                    <label>Check ID</label>
                    <p><span class="badge bg-secondary fs-6">#@Model.CheckID</span></p>
                </div>
                <div class="detail-item">
                    <label>Officer ID</label>
                    <p>#@Model.OfficerID</p>
                </div>
                <div class="detail-item">
                    <label>Assessment Date</label>
                    <p>@Model.Date.ToString("dd MMMM yyyy")</p>
                </div>
                <div class="detail-item">
                    <label>Eligibility Result</label>
                    <p>
                        @if (Model.Result.Equals("Eligible", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="status-badge status-fully-disbursed fs-6">
                                <i class="bi bi-check-circle-fill"></i> Eligible
                            </span>
                        }
                        else if (Model.Result.Equals("Ineligible", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="status-badge status-failed fs-6">
                                <i class="bi bi-x-circle-fill"></i> Ineligible
                            </span>
                        }
                        else if (Model.Result.Equals("Approved", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="status-badge status-fully-disbursed fs-6">
                                <i class="bi bi-check-circle-fill"></i> Approved
                            </span>
                        }
                        else if (Model.Result.Equals("Rejected", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="status-badge status-failed fs-6">
                                <i class="bi bi-x-circle-fill"></i> Rejected
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-warning fs-6">@Model.Result</span>
                        }
                    </p>
                </div>
                <div class="detail-item">
                    <label>Result Code</label>
                    <p><span class="badge bg-secondary fs-6">@Model.ResultCode</span></p>
                </div>
                <div class="detail-item" style="grid-column: span 2;">
                    <label>Assessment Notes</label>
                    <p class="border p-3 bg-light rounded">@Model.Notes</p>
                </div>
            </div>
        </div>

        @if (Model.Result.Equals("Approved", StringComparison.OrdinalIgnoreCase) || 
             Model.Result.Equals("Eligible", StringComparison.OrdinalIgnoreCase))
        {
            <div class="alert alert-success">
                <i class="bi bi-check-circle-fill"></i>
                <strong>Application Approved!</strong> The welfare application has been approved and a benefit has been created automatically.
            </div>
        }
        else if (Model.Result.Equals("Rejected", StringComparison.OrdinalIgnoreCase) || 
                 Model.Result.Equals("Ineligible", StringComparison.OrdinalIgnoreCase))
        {
            <div class="alert alert-danger">
                <i class="bi bi-x-circle-fill"></i>
                <strong>Application Rejected!</strong> The welfare application has been rejected. Benefits and disbursements are not allowed for this application.
            </div>
        }
    </div>

    <div class="col-md-4">
        <div class="content-card">
            <h5 class="mb-3">Actions</h5>
            <div class="d-grid gap-2">
                <a asp-action="Edit" asp-route-id="@Model.CheckID" class="btn btn-modern btn-warning-modern">
                    <i class="bi bi-pencil"></i> Edit Check
                </a>

                @if (Model.ApplicationID > 0)
                {
                    <a asp-controller="WelfareApplication" asp-action="Details" asp-route-id="@Model.ApplicationID" class="btn btn-modern btn-info-modern">
                        <i class="bi bi-file-earmark-text"></i> View Application
                    </a>
                }

                <a asp-action="Delete" asp-route-id="@Model.CheckID" class="btn btn-modern btn-danger-modern">
                    <i class="bi bi-trash"></i> Delete Check
                </a>

                <a asp-action="Index" class="btn btn-modern btn-secondary-modern">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>

        <div class="content-card mt-3">
            <h5 class="mb-3">Timeline</h5>
            <div class="timeline">
                <div class="timeline-item">
                    <i class="bi bi-file-earmark-text text-primary"></i>
                    <div>
                        <strong>Application Submitted</strong>
                        @if (Model.WelfareApplication != null)
                        {
                            <small class="text-muted d-block">@Model.WelfareApplication.SubmittedDate.ToString("dd MMM yyyy")</small>
                        }
                    </div>
                </div>
                <div class="timeline-item">
                    <i class="bi bi-clipboard-check text-info"></i>
                    <div>
                        <strong>Eligibility Check</strong>
                        <small class="text-muted d-block">@Model.Date.ToString("dd MMM yyyy")</small>
                    </div>
                </div>
                <div class="timeline-item">
                    @if (Model.Result.Equals("Approved", StringComparison.OrdinalIgnoreCase) || 
                         Model.Result.Equals("Eligible", StringComparison.OrdinalIgnoreCase))
                    {
                        <i class="bi bi-check-circle text-success"></i>
                        <div>
                            <strong>Decision: Approved</strong>
                            <small class="text-muted d-block">@Model.Date.ToString("dd MMM yyyy")</small>
                        </div>
                    }
                    else
                    {
                        <i class="bi bi-x-circle text-danger"></i>
                        <div>
                            <strong>Decision: Rejected</strong>
                            <small class="text-muted d-block">@Model.Date.ToString("dd MMM yyyy")</small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        .timeline {
            position: relative;
            padding-left: 30px;
        }
        .timeline::before {
            content: '';
            position: absolute;
            left: 8px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: #dee2e6;
        }
        .timeline-item {
            position: relative;
            margin-bottom: 20px;
            display: flex;
            align-items: start;
            gap: 10px;
        }
        .timeline-item i {
            font-size: 1.2rem;
            position: relative;
            z-index: 1;
            background: white;
        }
    </style>
}
