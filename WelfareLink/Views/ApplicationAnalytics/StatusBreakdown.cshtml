@{
    ViewData["Title"] = "Status Breakdown";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="display-4">@ViewData["Title"]</h1>
            <p class="lead">Detailed application status analysis</p>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-12">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5>Application Status Distribution</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.StatusBreakdown != null && ViewBag.StatusBreakdown.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Status</th>
                                        <th>Count</th>
                                        <th>Percentage</th>
                                        <th>Visual</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in ViewBag.StatusBreakdown)
                                    {
                                        <tr>
                                            <td>
                                                @if (item.Status == "Pending")
                                                {
                                                    <span class="badge bg-warning text-dark">@item.Status</span>
                                                }
                                                else if (item.Status == "Approved")
                                                {
                                                    <span class="badge bg-success">@item.Status</span>
                                                }
                                                else if (item.Status == "Rejected")
                                                {
                                                    <span class="badge bg-danger">@item.Status</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-info">@item.Status</span>
                                                }
                                            </td>
                                            <td><strong>@item.Count</strong></td>
                                            <td>@Math.Round(item.Percentage, 2)%</td>
                                            <td>
                                                <div class="progress" style="height: 25px;">
                                                    @{
                                                        var bgClass = item.Status == "Pending" ? "bg-warning" :
                                                                     item.Status == "Approved" ? "bg-success" :
                                                                     item.Status == "Rejected" ? "bg-danger" : "bg-info";
                                                    }
                                                    <div class="progress-bar @bgClass" role="progressbar" 
                                                         style="width: @item.Percentage%" 
                                                         aria-valuenow="@item.Percentage" aria-valuemin="0" aria-valuemax="100">
                                                        @Math.Round(item.Percentage, 1)%
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> No status data available
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
