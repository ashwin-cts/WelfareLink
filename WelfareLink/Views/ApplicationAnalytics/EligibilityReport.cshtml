@{
    ViewData["Title"] = "Eligibility Report";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="display-4">@ViewData["Title"]</h1>
            <p class="lead">Eligibility check performance analysis</p>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-12">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>

    <!-- Result Breakdown -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5>Eligibility Check Results Distribution</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.ResultBreakdown != null && ViewBag.ResultBreakdown.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Result</th>
                                        <th>Count</th>
                                        <th>Percentage</th>
                                        <th>Visual</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in ViewBag.ResultBreakdown)
                                    {
                                        <tr>
                                            <td>
                                                @if (item.Result.ToLower() == "eligible")
                                                {
                                                    <span class="badge bg-success">@item.Result</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">@item.Result</span>
                                                }
                                            </td>
                                            <td><strong>@item.Count</strong></td>
                                            <td>@Math.Round(item.Percentage, 2)%</td>
                                            <td>
                                                <div class="progress" style="height: 25px;">
                                                    @{
                                                        var bgClass = item.Result.ToLower() == "eligible" ? "bg-success" : "bg-danger";
                                                    }
                                                    <div class="progress-bar @bgClass" role="progressbar" 
                                                         style="width: @item.Percentage%" 
                                                         aria-valuenow="@item.Percentage" aria-valuemin="0" aria-valuemax="100">
                                                        @Math.Round(item.Percentage, 1)%
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> No eligibility check data available
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Checks by Month -->
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5>Eligibility Checks by Month</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.ChecksByMonth != null && ViewBag.ChecksByMonth.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Month</th>
                                        <th>Total Checks</th>
                                        <th>Eligible</th>
                                        <th>Ineligible</th>
                                        <th>Eligibility Rate</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var month in ViewBag.ChecksByMonth)
                                    {
                                        var eligibilityRate = month.Total > 0 ? (month.Eligible * 100.0 / month.Total) : 0;
                                        <tr>
                                            <td><strong>@month.Month</strong></td>
                                            <td><span class="badge bg-primary">@month.Total</span></td>
                                            <td><span class="badge bg-success">@month.Eligible</span></td>
                                            <td><span class="badge bg-danger">@month.Ineligible</span></td>
                                            <td>
                                                <div class="progress" style="height: 25px;">
                                                    <div class="progress-bar bg-success" role="progressbar" 
                                                         style="width: @eligibilityRate%" 
                                                         aria-valuenow="@eligibilityRate" aria-valuemin="0" aria-valuemax="100">
                                                        @Math.Round(eligibilityRate, 1)%
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> No monthly check data available
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
