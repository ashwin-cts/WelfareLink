@model WelfareLink.Models.WelfareApplication

@{
    ViewData["Title"] = "Edit Application";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="display-4">@ViewData["Title"]</h1>
            <p class="lead">Edit application details</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-warning">
                    <h5>Edit Application Form</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <input type="hidden" asp-for="ApplicationID" />

                        <div class="mb-3">
                            <label asp-for="CitizenID" class="form-label"></label>
                            <input asp-for="CitizenID" type="number" class="form-control" />
                            <span asp-validation-for="CitizenID" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProgramID" class="form-label"></label>
                            <input asp-for="ProgramID" type="number" class="form-control" />
                            <span asp-validation-for="ProgramID" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SubmittedDate" class="form-label"></label>
                            <input asp-for="SubmittedDate" type="date" class="form-control" />
                            <span asp-validation-for="SubmittedDate" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="Pending">Pending</option>
                                <option value="Under Review">Under Review</option>
                                <option value="Approved">Approved</option>
                                <option value="Rejected">Rejected</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-between mt-4">
                            <a asp-action="Details" asp-route-id="@Model.ApplicationID" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-circle"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
