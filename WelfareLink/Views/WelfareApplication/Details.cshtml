@model WelfareLink.Models.WelfareApplication

@{
    ViewData["Title"] = "Application Details";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="display-4">@ViewData["Title"]</h1>
            <p class="lead">Application ID: @Model.ApplicationID</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">
                    <h5>Application Information</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Application ID</dt>
                        <dd class="col-sm-8">@Model.ApplicationID</dd>

                        <dt class="col-sm-4">Citizen ID</dt>
                        <dd class="col-sm-8">@Model.CitizenID</dd>

                        <dt class="col-sm-4">Program ID</dt>
                        <dd class="col-sm-8">@Model.ProgramID</dd>

                        <dt class="col-sm-4">Submitted Date</dt>
                        <dd class="col-sm-8">@Model.SubmittedDate.ToString("dd MMMM yyyy")</dd>

                        <dt class="col-sm-4">Current Status</dt>
                        <dd class="col-sm-8">
                            @if (Model.Status == "Pending")
                            {
                                <span class="badge bg-warning text-dark fs-6">@Model.Status</span>
                            }
                            else if (Model.Status == "Approved")
                            {
                                <span class="badge bg-success fs-6">@Model.Status</span>
                            }
                            else if (Model.Status == "Rejected")
                            {
                                <span class="badge bg-danger fs-6">@Model.Status</span>
                            }
                            else
                            {
                                <span class="badge bg-info fs-6">@Model.Status</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">
                    <h5>Eligibility Check History</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">
                        <i class="bi bi-info-circle"></i> 
                        Eligibility checks performed by Welfare Officers will appear here.
                    </p>
                    <a asp-controller="EligibilityCheck" asp-action="Create" asp-route-applicationId="@Model.ApplicationID" 
                       class="btn btn-primary">
                        <i class="bi bi-clipboard-check"></i> Perform Eligibility Check
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header">
                    <h5>Actions</h5>
                </div>
                <div class="card-body d-grid gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.ApplicationID" class="btn btn-warning">
                        <i class="bi bi-pencil"></i> Edit Application
                    </a>

                    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#updateStatusModal">
                        <i class="bi bi-arrow-repeat"></i> Update Status
                    </button>

                    <a asp-action="Delete" asp-route-id="@Model.ApplicationID" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Delete Application
                    </a>

                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5>Application Timeline</h5>
                </div>
                <div class="card-body">
                    <div class="timeline">
                        <div class="timeline-item">
                            <i class="bi bi-check-circle-fill text-success"></i>
                            <strong>Submitted</strong>
                            <br />
                            <small>@Model.SubmittedDate.ToString("dd MMM yyyy")</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Update Status Modal -->
<div class="modal fade" id="updateStatusModal" tabindex="-1" aria-labelledby="updateStatusModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="updateStatusModalLabel">Update Application Status</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="UpdateStatus" method="post">
                <input type="hidden" name="id" value="@Model.ApplicationID" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="status" class="form-label">Select New Status</label>
                        <select name="status" id="status" class="form-select" required>
                            <option value="">Choose...</option>
                            <option value="Pending">Pending</option>
                            <option value="Under Review">Under Review</option>
                            <option value="Approved">Approved</option>
                            <option value="Rejected">Rejected</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update Status</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
