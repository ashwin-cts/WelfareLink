@model IEnumerable<WelfareLink.Models.WelfareApplication>

@{
    ViewData["Title"] = "Application Review Dashboard";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="display-4">@ViewData["Title"]</h1>
            <p class="lead">Review and manage welfare applications</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row mb-3">
        <div class="col-md-12">
            <div class="btn-group" role="group">
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Submit New Application
                </a>
                <a asp-action="Pending" class="btn btn-warning">
                    <i class="bi bi-clock"></i> Pending Applications
                </a>
                <a asp-action="MyApplications" class="btn btn-info">
                    <i class="bi bi-person-check"></i> My Applications
                </a>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5>Filter Applications</h5>
                </div>
                <div class="card-body">
                    <form asp-action="ByStatus" method="get" class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Status</label>
                            <select name="status" class="form-select">
                                <option value="">All Status</option>
                                <option value="Pending">Pending</option>
                                <option value="Under Review">Under Review</option>
                                <option value="Approved">Approved</option>
                                <option value="Rejected">Rejected</option>
                            </select>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-secondary">Filter</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5>Applications List</h5>
                </div>
                <div class="card-body">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Application ID</th>
                                        <th>Citizen ID</th>
                                        <th>Program ID</th>
                                        <th>Submitted Date</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.ApplicationID</td>
                                            <td>@item.CitizenID</td>
                                            <td>@item.ProgramID</td>
                                            <td>@item.SubmittedDate.ToString("dd MMM yyyy")</td>
                                            <td>
                                                @if (item.Status == "Pending")
                                                {
                                                    <span class="badge bg-warning text-dark">@item.Status</span>
                                                }
                                                else if (item.Status == "Approved")
                                                {
                                                    <span class="badge bg-success">@item.Status</span>
                                                }
                                                else if (item.Status == "Rejected")
                                                {
                                                    <span class="badge bg-danger">@item.Status</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-info">@item.Status</span>
                                                }
                                            </td>
                                            <td>
                                                <a asp-action="Details" asp-route-id="@item.ApplicationID" class="btn btn-sm btn-info" title="View Details">
                                                    <i class="bi bi-eye"></i> Details
                                                </a>
                                                <a asp-action="Edit" asp-route-id="@item.ApplicationID" class="btn btn-sm btn-warning" title="Edit">
                                                    <i class="bi bi-pencil"></i> Edit
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@item.ApplicationID" class="btn btn-sm btn-danger" title="Delete">
                                                    <i class="bi bi-trash"></i> Delete
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> No applications found.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
