@model WelfareLink.Models.Benefit

@{
    ViewData["Title"] = "Delete Benefit";
}

<div class="page-header">
    <h1><i class="bi bi-trash-fill text-danger"></i> Delete Benefit</h1>
    <a asp-action="Index" class="btn-modern btn-secondary-modern">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</div>

<div class="content-card">
    <div class="alert-delete">
        <h4><i class="bi bi-exclamation-triangle-fill"></i> Confirm Deletion</h4>
        <p class="mb-0">Are you sure you want to permanently delete this benefit? This action cannot be undone.</p>
    </div>

    <div class="detail-grid mb-4">
        <div class="detail-item">
            <label><i class="bi bi-hash"></i> Benefit ID</label>
            <p>@Model?.BenefitID</p>
        </div>

        <div class="detail-item">
            <label><i class="bi bi-file-earmark-text"></i> Application ID</label>
            <p>@Model?.ApplicationID</p>
        </div>

        <div class="detail-item">
            <label><i class="bi bi-tag"></i> Benefit Type</label>
            <p>@Model?.Type</p>
        </div>

        <div class="detail-item">
            <label><i class="bi bi-currency-rupee"></i> Amount</label>
            <p><strong style="color: #ef4444;">₹@Model?.Amount.ToString("N2")</strong></p>
        </div>

        <div class="detail-item">
            <label><i class="bi bi-calendar-event"></i> Date</label>
            <p>@Model?.Date.ToString("MMMM dd, yyyy")</p>
        </div>

        <div class="detail-item">
            <label><i class="bi bi-flag"></i> Status</label>
            <p>@Model?.Status</p>
        </div>
    </div>

    <hr class="my-4" />

    <form asp-action="Delete">
        <input type="hidden" asp-for="BenefitID" />
        <div class="d-flex gap-3">
            <button type="submit" class="btn-modern btn-danger-modern">
                <i class="bi bi-trash"></i> Yes, Delete Permanently
            </button>
            <a asp-action="Index" class="btn-modern btn-secondary-modern">
                <i class="bi bi-x-circle"></i> Cancel
            </a>
        </div>
    </form>
</div>
