@model WelfareLink.Models.Benefit

@{
    ViewData["Title"] = "Benefit Details";
}

<div class="page-header">
    <h1><i class="bi bi-info-circle-fill"></i> Benefit Details</h1>
    <a asp-action="Index" class="btn-modern btn-secondary-modern">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</div>

<div class="content-card">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                    <i class="bi bi-gift-fill text-white" style="font-size: 1.8rem;"></i>
                </div>
                <div>
                    <h3 class="mb-0">Benefit #@Model?.BenefitID</h3>
                    @{
                        var statusClass = Model?.Status?.ToLower() switch
                        {
                            "allocated" => "status-allocated",
                            "disbursed" => "status-disbursed",
                            "pending" => "status-pending",
                            _ => "status-pending"
                        };
                    }
                    <span class="status-badge @statusClass mt-1">
                        <i class="bi bi-circle-fill" style="font-size: 8px;"></i> @Model?.Status
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="detail-grid">
        <div class="detail-item">
            <label><i class="bi bi-hash"></i> Benefit ID</label>
            <p>@Model?.BenefitID</p>
        </div>

        <div class="detail-item">
            <label><i class="bi bi-file-earmark-text"></i> Application ID</label>
            <p>@Model?.ApplicationID</p>
        </div>

        <div class="detail-item">
            <label><i class="bi bi-tag"></i> Benefit Type</label>
            <p>@Model?.Type</p>
        </div>

        <div class="detail-item">
            <label><i class="bi bi-currency-rupee"></i> Amount</label>
            <p><strong style="color: #10b981; font-size: 1.3rem;">₹@Model?.Amount.ToString("N2")</strong></p>
        </div>

        <div class="detail-item">
            <label><i class="bi bi-calendar-event"></i> Allocation Date</label>
            <p>@Model?.Date.ToString("MMMM dd, yyyy")</p>
        </div>

        <div class="detail-item">
            <label><i class="bi bi-flag"></i> Current Status</label>
            <p>@Model?.Status</p>
        </div>
    </div>

    <hr class="my-4" />

    <div class="d-flex gap-3">
        <a asp-action="Edit" asp-route-id="@Model?.BenefitID" class="btn-modern btn-warning-modern">
            <i class="bi bi-pencil"></i> Edit Benefit
        </a>
        <a asp-action="Delete" asp-route-id="@Model?.BenefitID" class="btn-modern btn-danger-modern">
            <i class="bi bi-trash"></i> Delete
        </a>
        <a asp-action="Index" class="btn-modern btn-secondary-modern">
            <i class="bi bi-list"></i> View All
        </a>
    </div>
</div>
