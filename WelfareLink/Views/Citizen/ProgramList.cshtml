@model IEnumerable<WelfareLink.Models.WelfareProgram>

@{
    ViewData["Title"] = "Available Programs";
    var appliedProgramIds = ViewBag.AppliedProgramIds as HashSet<int> ?? new HashSet<int>();
    int citizenId = ViewBag.CitizenId ?? 0;
}

<div class="page-header">
    <h1><i class="bi bi-grid-3x3-gap-fill"></i> Available Welfare Programs</h1>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="content-card">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox" style="font-size: 4rem; color: #cbd5e1;"></i>
            <h4 class="mt-3 text-muted">No programs available</h4>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-modern">
                <thead>
                    <tr>
                        <th><i class="bi bi-hash"></i> ID</th>
                        <th><i class="bi bi-diagram-3"></i> Program Title</th>
                        <th><i class="bi bi-calendar-range"></i> Duration</th>
                        <th><i class="bi bi-currency-rupee"></i> Budget</th>
                        <th><i class="bi bi-flag"></i> Status</th>
                        <th><i class="bi bi-gear"></i> Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var program in Model)
                    {
                        var isApplied = appliedProgramIds.Contains(program.ProgramID);
                        <tr>
                            <td><strong>#@program.ProgramID</strong></td>
                            <td>
                                <strong>@program.Title</strong>
                                <br /><small class="text-muted">@(program.Description?.Length > 60 ? program.Description.Substring(0, 60) + "…" : program.Description)</small>
                            </td>
                            <td>
                                <small><i class="bi bi-calendar-check text-success"></i> @program.StartDate.ToString("dd MMM yyyy")</small><br />
                                <small><i class="bi bi-calendar-x text-danger"></i> @program.EndDate.ToString("dd MMM yyyy")</small>
                            </td>
                            <td><strong>₹@program.Budget.ToString("N2")</strong></td>
                            <td>
                                @{
                                    var statusClass = program.Status?.ToLower() switch
                                    {
                                        "active" => "status-allocated",
                                        "completed" => "status-fully-disbursed",
                                        "inactive" => "status-failed",
                                        _ => "status-pending"
                                    };
                                }
                                <span class="status-badge @statusClass">
                                    <i class="bi bi-circle-fill" style="font-size: 8px;"></i> @(program.Status ?? "Active")
                                </span>
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <!-- Eye: view details modal -->
                                    <button type="button"
                                            class="btn-modern btn-info-modern btn-sm"
                                            data-bs-toggle="modal"
                                            data-bs-target="#programModal-@program.ProgramID"
                                            title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </button>

                                    <!-- Apply / Applied -->
                                    @if (isApplied)
                                    {
                                        <button class="btn-modern btn-secondary-modern btn-sm" disabled title="Already applied">
                                            <i class="bi bi-check-circle-fill"></i> Applied
                                        </button>
                                    }
                                    else
                                    {
                                        <a asp-action="SelectDocuments" asp-controller="Citizen" asp-route-programId="@program.ProgramID"
                                           class="btn-modern btn-success-modern btn-sm" title="Apply for this program">
                                            <i class="bi bi-send"></i> Apply
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>

                        <!-- Details Modal -->
                        <div class="modal fade" id="programModal-@program.ProgramID" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-lg modal-dialog-centered">
                                <div class="modal-content" style="border-radius: 16px; overflow: hidden;">
                                    <div class="modal-header" style="background: var(--primary-gradient);">
                                        <h5 class="modal-title text-white">
                                            <i class="bi bi-diagram-3-fill me-2"></i> @program.Title
                                        </h5>
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body p-4">
                                        <div class="detail-grid">
                                            <div class="detail-item">
                                                <label><i class="bi bi-hash"></i> Program ID</label>
                                                <p>#@program.ProgramID</p>
                                            </div>
                                            <div class="detail-item">
                                                <label><i class="bi bi-flag"></i> Status</label>
                                                <p>@(program.Status ?? "Active")</p>
                                            </div>
                                            <div class="detail-item">
                                                <label><i class="bi bi-calendar-check"></i> Start Date</label>
                                                <p>@program.StartDate.ToString("dd MMMM yyyy")</p>
                                            </div>
                                            <div class="detail-item">
                                                <label><i class="bi bi-calendar-x"></i> End Date</label>
                                                <p>@program.EndDate.ToString("dd MMMM yyyy")</p>
                                            </div>
                                            <div class="detail-item">
                                                <label><i class="bi bi-currency-rupee"></i> Budget</label>
                                                <p><strong style="color:#10b981;">₹@program.Budget.ToString("N2")</strong></p>
                                            </div>
                                        </div>
                                        <div class="mt-3">
                                            <label class="form-label-modern"><i class="bi bi-card-text me-1"></i> Description</label>
                                            <div class="detail-item">
                                                <p>@program.Description</p>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn-modern btn-secondary-modern" data-bs-dismiss="modal">
                                            <i class="bi bi-x-circle"></i> Close
                                        </button>
                                        @if (!isApplied)
                                        {
                                            <a asp-action="SelectDocuments" asp-controller="Citizen" asp-route-programId="@program.ProgramID"
                                               class="btn-modern btn-success-modern">
                                                <i class="bi bi-send"></i> Apply Now
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="btn-modern btn-secondary-modern" style="opacity:.7;">
                                                <i class="bi bi-check-circle-fill"></i> Already Applied
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
