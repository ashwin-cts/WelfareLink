@model WelfareLink.Models.WelfareApplication

@{
    ViewData["Title"] = "Delete Application";
}

<div class="page-header">
    <h1><i class="bi bi-trash-fill text-danger"></i> Delete Application</h1>
    <a asp-controller="Citizen" asp-action="ApplicationDetails" asp-route-id="@Model.ApplicationID"
       class="btn-modern btn-secondary-modern">
        <i class="bi bi-arrow-left"></i> Back to Details
    </a>
</div>

<div class="content-card" style="max-width:680px;">
    <div class="alert alert-danger d-flex align-items-start gap-3 mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-4 flex-shrink-0 mt-1"></i>
        <div>
            <h6 class="mb-1 fw-semibold">This action cannot be undone</h6>
            <p class="mb-0">Deleting this application will permanently remove it from the system. Are you sure you want to continue?</p>
        </div>
    </div>

    <div class="detail-grid mb-4">
        <div class="detail-item">
            <label><i class="bi bi-hash"></i> Application ID</label>
            <p>#@Model.ApplicationID</p>
        </div>
        <div class="detail-item">
            <label><i class="bi bi-diagram-3"></i> Program</label>
            <p>@(Model.Program?.Title ?? $"Program #{Model.ProgramID}")</p>
        </div>
        <div class="detail-item">
            <label><i class="bi bi-calendar-event"></i> Submitted Date</label>
            <p>@Model.SubmittedDate.ToString("dd MMMM yyyy")</p>
        </div>
        <div class="detail-item">
            <label><i class="bi bi-flag"></i> Status</label>
            <p><span class="status-badge status-pending"><i class="bi bi-circle-fill" style="font-size:8px;"></i> @Model.Status</span></p>
        </div>
    </div>

    <div class="d-flex gap-3">
        <form asp-controller="Citizen" asp-action="DeleteApplication" asp-route-id="@Model.ApplicationID" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-modern btn-danger-modern">
                <i class="bi bi-trash-fill"></i> Confirm Delete
            </button>
        </form>
        <a asp-controller="Citizen" asp-action="ApplicationDetails" asp-route-id="@Model.ApplicationID"
           class="btn-modern btn-secondary-modern">
            <i class="bi bi-x-circle"></i> Cancel
        </a>
    </div>
</div>
