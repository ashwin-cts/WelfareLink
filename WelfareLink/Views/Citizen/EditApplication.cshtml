@model WelfareLink.Models.WelfareApplication

@{
    ViewData["Title"] = Model.Status == "Rejected" ? "Edit & Re-submit Application" : "Edit Application";
    bool isRejected = Model.Status == "Rejected";
}

<div class="page-header">
    <h1>
        <i class="bi bi-pencil-square"></i>
        @ViewData["Title"]
    </h1>
    <a asp-controller="Citizen" asp-action="ApplicationDetails" asp-route-id="@Model.ApplicationID"
       class="btn-modern btn-secondary-modern">
        <i class="bi bi-arrow-left"></i> Cancel
    </a>
</div>

@if (isRejected)
{
    <div class="alert alert-warning mb-3">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Re-submitting a rejected application.</strong>
        Once saved, the status will automatically reset to <strong>Pending</strong> for review.
    </div>
}

<div class="content-card">
    <form asp-action="EditApplication" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

        <input type="hidden" asp-for="ApplicationID" />
        <input type="hidden" asp-for="CitizenID" />
        <input type="hidden" asp-for="Status" />
        <input type="hidden" asp-for="SubmittedDate" />

        <div class="detail-grid">
            <div>
                <label class="form-label-modern"><i class="bi bi-diagram-3 me-1"></i> Welfare Program</label>
                <select asp-for="ProgramID" asp-items="ViewBag.ProgramList" class="form-select" style="border-radius:12px;border:2px solid #e2e8f0;padding:.8rem;">
                    <option value="">-- Select a Program --</option>
                </select>
                <span asp-validation-for="ProgramID" class="text-danger small"></span>
            </div>
        </div>

        <div class="d-flex gap-3 mt-4">
            <button type="submit" class="btn-modern btn-success-modern">
                <i class="bi bi-check-circle"></i>
                @(isRejected ? "Re-submit Application" : "Save Changes")
            </button>
            <a asp-controller="Citizen" asp-action="ApplicationDetails" asp-route-id="@Model.ApplicationID"
               class="btn-modern btn-secondary-modern">
                <i class="bi bi-x-circle"></i> Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
