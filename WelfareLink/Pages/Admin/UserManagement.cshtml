@page
@model WelfareLink.Pages.Admin.UserManagementModel
@{
    ViewData["Title"] = "User Management - WelfareLink Admin";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="fas fa-users me-2"></i>User Management</h2>
            <p class="text-muted mb-0">Create, manage, and monitor user accounts</p>
        </div>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createUserModal">
            <i class="fas fa-user-plus me-2"></i>Create New User
        </button>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>
            @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Search and Filter Section -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Search Users</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" name="search" class="form-control" 
                               value="@Model.SearchTerm" placeholder="Name, email, or phone" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Filter by Role</label>
                    <select name="role" class="form-select">
                        <option value="">All Roles</option>
                        <option value="Admin" selected="@(Model.RoleFilter == "Admin")">Admin</option>
                        <option value="Manager" selected="@(Model.RoleFilter == "Manager")">Manager</option>
                        <option value="Officer" selected="@(Model.RoleFilter == "Officer")">Officer</option>
                        <option value="Compliance" selected="@(Model.RoleFilter == "Compliance")">Compliance</option>
                        <option value="Auditor" selected="@(Model.RoleFilter == "Auditor")">Auditor</option>
                        <option value="Citizen" selected="@(Model.RoleFilter == "Citizen")">Citizen</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Filter by Status</label>
                    <select name="status" class="form-select">
                        <option value="">All Statuses</option>
                        <option value="Active" selected="@(Model.StatusFilter == "Active")">Active</option>
                        <option value="Inactive" selected="@(Model.StatusFilter == "Inactive")">Inactive</option>
                        <option value="Suspended" selected="@(Model.StatusFilter == "Suspended")">Suspended</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-outline-primary d-block w-100">
                        <i class="fas fa-filter me-2"></i>Filter
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Users Table -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-table me-2"></i>Users (@Model.Users.Count)</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Phone</th>
                            <th>Last Login</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar bg-primary text-white rounded-circle me-3" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                            @user.Name.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <strong>@user.Name</strong>
                                            <br><small class="text-muted">ID: @user.UserID</small>
                                        </div>
                                    </div>
                                </td>
                                <td>@user.Email</td>
                                <td>
                                    <span class="badge bg-@GetRoleBadgeColor(user.Role)">@user.Role</span>
                                </td>
                                <td>@(string.IsNullOrEmpty(user.Phone) ? "Not provided" : user.Phone)</td>
                                <td>
                                    @if (user.LastLogin.HasValue)
                                    {
                                        <span>@user.LastLogin.Value.ToString("MMM dd, yyyy HH:mm")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Never</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-success">Active</span>
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <button type="button" class="btn btn-sm btn-outline-info" 
                                                onclick="viewUser('@user.UserID')" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-warning" 
                                                onclick="editUser('@user.UserID')" title="Edit User">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" 
                                                onclick="suspendUser('@user.UserID', '@user.Name')" title="Suspend User">
                                            <i class="fas fa-ban"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Create User Modal -->
<div class="modal fade" id="createUserModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" asp-page-handler="Create">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-user-plus me-2"></i>Create New User</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Input.Name" class="form-label">Full Name *</label>
                            <input asp-for="Input.Name" class="form-control" required />
                            <span asp-validation-for="Input.Name" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.Role" class="form-label">Role *</label>
                            <select asp-for="Input.Role" class="form-select" required>
                                <option value="">Select Role</option>
                                <option value="Admin">Admin</option>
                                <option value="Manager">Manager</option>
                                <option value="Officer">Officer</option>
                                <option value="Compliance">Compliance</option>
                                <option value="Auditor">Auditor</option>
                                <option value="Citizen">Citizen</option>
                            </select>
                            <span asp-validation-for="Input.Role" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.Email" class="form-label">Email Address *</label>
                            <input asp-for="Input.Email" type="email" class="form-control" required />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.Phone" class="form-label">Phone Number</label>
                            <input asp-for="Input.Phone" type="tel" class="form-control" />
                            <span asp-validation-for="Input.Phone" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.Status" class="form-label">Status *</label>
                            <select asp-for="Input.Status" class="form-select" required>
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                            <span asp-validation-for="Input.Status" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.TemporaryPassword" class="form-label">Temporary Password</label>
                            <input asp-for="Input.TemporaryPassword" type="password" class="form-control" 
                                   placeholder="Leave blank to auto-generate" />
                            <small class="form-text text-muted">User will be required to change this on first login</small>
                            <span asp-validation-for="Input.TemporaryPassword" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-2"></i>Create User
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@functions {
    string GetRoleBadgeColor(string role)
    {
        return role switch
        {
            "Admin" => "danger",
            "Manager" => "warning",
            "Officer" => "info",
            "Compliance" => "secondary",
            "Auditor" => "dark",
            "Citizen" => "primary",
            _ => "light"
        };
    }
}

@section Scripts {
    <script>
        function viewUser(userId) {
            // Implement user details view
            alert('View user: ' + userId);
        }

        function editUser(userId) {
            // Implement user edit functionality
            alert('Edit user: ' + userId);
        }

        function suspendUser(userId, userName) {
            if (confirm('Are you sure you want to suspend ' + userName + '?')) {
                var reason = prompt('Please enter reason for suspension:');
                if (reason) {
                    // Make AJAX call to suspend user
                    fetch('/Admin/UserManagement?handler=Suspend', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: JSON.stringify({ userId: userId, reason: reason })
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            alert('User suspended successfully');
                            location.reload();
                        } else {
                            alert('Error: ' + data.message);
                        }
                    });
                }
            }
        }
    </script>
}