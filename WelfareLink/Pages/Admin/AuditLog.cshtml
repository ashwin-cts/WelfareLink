@page
@model WelfareLink.Pages.Admin.AuditLogModel
@{
    ViewData["Title"] = "Audit Log - WelfareLink";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="fas fa-clipboard-list me-2"></i>Audit Log Viewer</h2>
            <p class="text-muted mb-0">Monitor all system activities and user actions</p>
        </div>
        <div>
            <a asp-page-handler="Export" class="btn btn-success me-2">
                <i class="fas fa-download me-2"></i>Export to CSV
            </a>
            <button type="button" class="btn btn-primary" onclick="refreshLogs()">
                <i class="fas fa-sync-alt me-2"></i>Refresh
            </button>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Filter Audit Logs</h5>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">User</label>
                    <select asp-for="Filter.UserId" class="form-select">
                        <option value="">All Users</option>
                        @foreach (var user in Model.Users)
                        {
                            <option value="@user.UserID" selected="@(Model.Filter.UserId == user.UserID)">
                                @user.Name (@user.Role)
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Action</label>
                    <select asp-for="Filter.Action" class="form-select">
                        <option value="">All Actions</option>
                        <option value="Login" selected="@(Model.Filter.Action == "Login")">Login</option>
                        <option value="Logout" selected="@(Model.Filter.Action == "Logout")">Logout</option>
                        <option value="Create" selected="@(Model.Filter.Action == "Create")">Create</option>
                        <option value="Update" selected="@(Model.Filter.Action == "Update")">Update</option>
                        <option value="Delete" selected="@(Model.Filter.Action == "Delete")">Delete</option>
                        <option value="View" selected="@(Model.Filter.Action == "View")">View</option>
                        <option value="Suspend" selected="@(Model.Filter.Action == "Suspend")">Suspend</option>
                        <option value="Activate" selected="@(Model.Filter.Action == "Activate")">Activate</option>
                        <option value="Failed Login" selected="@(Model.Filter.Action == "Failed Login")">Failed Login</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Resource</label>
                    <input asp-for="Filter.Resource" class="form-control" placeholder="Resource name" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Start Date</label>
                    <input asp-for="Filter.StartDate" type="date" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">End Date</label>
                    <input asp-for="Filter.EndDate" type="date" class="form-control" />
                </div>
                <div class="col-md-1">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-primary d-block w-100">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">@Model.AuditLogs.Count</h4>
                            <p class="mb-0">Total Records</p>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-list fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">@Model.AuditLogs.Count(a => a.Action == "Login")</h4>
                            <p class="mb-0">Login Events</p>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-sign-in-alt fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">@Model.AuditLogs.Count(a => a.Action == "Failed Login")</h4>
                            <p class="mb-0">Failed Logins</p>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-exclamation-triangle fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">@Model.AuditLogs.Select(a => a.UserID).Distinct().Count()</h4>
                            <p class="mb-0">Unique Users</p>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-users fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Audit Logs Table -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-table me-2"></i>Audit Trail</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Timestamp</th>
                            <th>User</th>
                            <th>Action</th>
                            <th>Resource</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.AuditLogs.OrderByDescending(a => a.Timestamp))
                        {
                            <tr class="@GetRowClass(log.Action)">
                                <td>
                                    <div>
                                        <strong>@log.Timestamp.ToString("MMM dd, yyyy")</strong>
                                        <br>
                                        <small class="text-muted">@log.Timestamp.ToString("HH:mm:ss")</small>
                                    </div>
                                </td>
                                <td>
                                    <div>
                                        <strong>@GetUserName(log.UserID)</strong>
                                        <br>
                                        <small class="text-muted">@log.UserID</small>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-@GetActionBadgeColor(log.Action)">
                                        <i class="@GetActionIcon(log.Action) me-1"></i>
                                        @log.Action
                                    </span>
                                </td>
                                <td>@log.Resource</td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-outline-info" 
                                            onclick="showDetails('@log.AuditLogID')" title="View Details">
                                        <i class="fas fa-info-circle"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            @if (!Model.AuditLogs.Any())
            {
                <div class="text-center py-5">
                    <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                    <h5 class="text-muted">No audit logs found</h5>
                    <p class="text-muted">Try adjusting your filter criteria</p>
                </div>
            }
        </div>
    </div>
</div>

@functions {
    string GetUserName(string userId)
    {
        var user = Model.Users.FirstOrDefault(u => u.UserID == userId);
        return user?.Name ?? "Unknown User";
    }

    string GetRowClass(string action)
    {
        return action switch
        {
            "Failed Login" => "table-danger",
            "Login" => "table-success",
            "Delete" => "table-warning",
            "Suspend" => "table-danger",
            _ => ""
        };
    }

    string GetActionBadgeColor(string action)
    {
        return action switch
        {
            "Login" => "success",
            "Logout" => "secondary",
            "Create" => "primary",
            "Update" => "info",
            "Delete" => "danger",
            "View" => "light",
            "Suspend" => "danger",
            "Activate" => "success",
            "Failed Login" => "danger",
            _ => "secondary"
        };
    }

    string GetActionIcon(string action)
    {
        return action switch
        {
            "Login" => "fas fa-sign-in-alt",
            "Logout" => "fas fa-sign-out-alt",
            "Create" => "fas fa-plus",
            "Update" => "fas fa-edit",
            "Delete" => "fas fa-trash",
            "View" => "fas fa-eye",
            "Suspend" => "fas fa-ban",
            "Activate" => "fas fa-check",
            "Failed Login" => "fas fa-exclamation-triangle",
            _ => "fas fa-cog"
        };
    }
}

@section Scripts {
    <script>
        function refreshLogs() {
            location.reload();
        }

        function showDetails(auditId) {
            // Implement details modal or expand functionality
            alert('Show details for audit log: ' + auditId);
        }

        // Auto-refresh every 30 seconds for real-time monitoring
        setInterval(function() {
            // Only refresh if no filters are applied to avoid disrupting user interaction
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.toString() === '') {
                location.reload();
            }
        }, 30000);
    </script>
}