@page
@model WelfareLink.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard - WelfareLink";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8f9fa;
        }
        .hero-section {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 60px 0;
            margin-bottom: 40px;
        }
        .card {
            border: none;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
            transition: transform 0.3s;
        }
        .card:hover {
            transform: translateY(-5px);
        }
        .stat-card {
            padding: 30px;
            text-align: center;
        }
        .stat-number {
            font-size: 3rem;
            font-weight: bold;
            margin: 10px 0;
        }
        .navbar-custom {
            background-color: #2c3e50;
        }
    </style>
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="bi bi-heart-pulse"></i> WelfareLink
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="/">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Audits/Index">Audits</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Compliance/Index">Compliance</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Users/Index">Users</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <div class="hero-section">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1 class="display-4">
                        <i class="bi bi-speedometer2"></i> WelfareLink Dashboard
                    </h1>
                    <p class="lead">Welcome to the WelfareLink Management System</p>
                    <p>Manage audits, compliance records, and users efficiently</p>
                </div>
                <div class="col-md-4 text-end">
                    <i class="bi bi-graph-up" style="font-size: 120px; opacity: 0.3;"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container mb-5">
        <!-- Statistics Cards -->
        <div class="row g-4 mb-5">
            <div class="col-md-3">
                <div class="card stat-card bg-primary text-white">
                    <i class="bi bi-clipboard-check" style="font-size: 3rem;"></i>
                    <div class="stat-number">@Model.TotalAudits</div>
                    <h5>Total Audits</h5>
                    <a href="/Audits/Index" class="btn btn-light btn-sm mt-3">View All</a>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card stat-card bg-warning text-white">
                    <i class="bi bi-clock-history" style="font-size: 3rem;"></i>
                    <div class="stat-number">@Model.PendingAudits</div>
                    <h5>Pending Audits</h5>
                    <a href="/Audits/Index?status=Pending" class="btn btn-light btn-sm mt-3">Review</a>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card stat-card bg-success text-white">
                    <i class="bi bi-file-earmark-check" style="font-size: 3rem;"></i>
                    <div class="stat-number">@Model.TotalCompliance</div>
                    <h5>Compliance Records</h5>
                    <a href="/Compliance/Index" class="btn btn-light btn-sm mt-3">View All</a>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card stat-card bg-info text-white">
                    <i class="bi bi-people" style="font-size: 3rem;"></i>
                    <div class="stat-number">@Model.TotalUsers</div>
                    <h5>Total Users</h5>
                    <a href="/Users/Index" class="btn btn-light btn-sm mt-3">Manage</a>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body text-center p-4">
                        <i class="bi bi-plus-circle text-primary" style="font-size: 3rem;"></i>
                        <h5 class="mt-3">Create New Audit</h5>
                        <p class="text-muted">Start a new audit process</p>
                        <a href="/Audits/Create" class="btn btn-primary">Create Audit</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card">
                    <div class="card-body text-center p-4">
                        <i class="bi bi-file-plus text-success" style="font-size: 3rem;"></i>
                        <h5 class="mt-3">Add Compliance Record</h5>
                        <p class="text-muted">Log a new compliance record</p>
                        <a href="/Compliance/Create" class="btn btn-success">Add Record</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card">
                    <div class="card-body text-center p-4">
                        <i class="bi bi-person-plus text-info" style="font-size: 3rem;"></i>
                        <h5 class="mt-3">Add New User</h5>
                        <p class="text-muted">Create a new user account</p>
                        <a href="/Users/Create" class="btn btn-info">Add User</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Activity -->
        <div class="row mt-5">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0"><i class="bi bi-clock"></i> Recent Activity</h5>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> 
                            <strong>Welcome to WelfareLink!</strong>
                            <p class="mb-0">Use the navigation menu above to manage audits, compliance records, and users.</p>
                        </div>
                        
                        <div class="row text-center mt-4">
                            <div class="col-md-3">
                                <div class="p-3">
                                    <i class="bi bi-check-circle text-success" style="font-size: 2rem;"></i>
                                    <h6 class="mt-2">System Ready</h6>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="p-3">
                                    <i class="bi bi-database text-primary" style="font-size: 2rem;"></i>
                                    <h6 class="mt-2">Database Connected</h6>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="p-3">
                                    <i class="bi bi-shield-check text-success" style="font-size: 2rem;"></i>
                                    <h6 class="mt-2">All Services Active</h6>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="p-3">
                                    <i class="bi bi-speedometer text-warning" style="font-size: 2rem;"></i>
                                    <h6 class="mt-2">Performance Optimal</h6>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-white text-center py-4 mt-5">
        <div class="container">
            <p class="mb-0">&copy; 2025 WelfareLink - Welfare Management System</p>
            <p class="mb-0"><small>Built with ASP.NET Core Razor Pages</small></p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
