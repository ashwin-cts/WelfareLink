@page
@model WelfareLink.Pages.Account.LogoutModel
@{
    ViewData["Title"] = "Logging Out - WelfareLink";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body text-center py-5">
                    <div class="mb-4">
                        <i class="fas fa-sign-out-alt fa-5x text-info"></i>
                    </div>
                    <h2 class="card-title">Logging Out...</h2>
                    <p class="card-text text-muted mb-4">
                        Please wait while we securely log you out of the system.
                    </p>
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Auto-redirect to login after a short delay to show the logout message
    setTimeout(function() {
        window.location.href = '/Account/Login?message=You have been logged out successfully';
    }, 2000);
</script>