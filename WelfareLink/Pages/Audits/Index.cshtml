@page
@model WelfareLink.Pages.Audits.IndexModel
@{
    ViewData["Title"] = "Audits Management";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/"><i class="bi bi-heart-pulse"></i> WelfareLink</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/Audits/Index">Audits</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Compliance/Index">Compliance</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Users/Index">Users</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1><i class="bi bi-clipboard-check"></i> Audits Management</h1>
            <a href="/Audits/Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> New Audit
            </a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">All Audits (@Model.Audits.Count())</h5>
            </div>
            <div class="card-body p-0">
                @if (Model.Audits.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Scope</th>
                                    <th>Officer</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var audit in Model.Audits)
                                {
                                    <tr>
                                        <td>@audit.Scope</td>
                                        <td>
                                            @if (audit.Officer != null)
                                            {
                                                <i class="bi bi-person"></i> @audit.Officer.Name
                                            }
                                            else
                                            {
                                                <span class="text-muted">N/A</span>
                                            }
                                        </td>
                                        <td>@audit.Date.ToString("MMM dd, yyyy")</td>
                                        <td>
                                            @{
                                                var badgeClass = audit.Status switch
                                                {
                                                    "Completed" => "success",
                                                    "Pending" => "warning",
                                                    "In Progress" => "primary",
                                                    _ => "secondary"
                                                };
                                            }
                                            <span class="badge bg-@badgeClass">@audit.Status</span>
                                        </td>
                                        <td class="text-end">
                                            <a href="/Audits/Details/@audit.AuditID" class="btn btn-sm btn-outline-info">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a href="/Audits/Edit/@audit.AuditID" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a href="/Audits/Delete/@audit.AuditID" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="p-5 text-center">
                        <i class="bi bi-inbox" style="font-size: 4rem; color: #ccc;"></i>
                        <p class="mt-3 text-muted">No audits found</p>
                        <a href="/Audits/Create" class="btn btn-primary">
                            <i class="bi bi-plus-circle"></i> Create First Audit
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
