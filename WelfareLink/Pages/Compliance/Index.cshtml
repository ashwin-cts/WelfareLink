@page
@model WelfareLink.Pages.Compliance.IndexModel
@{
    ViewData["Title"] = "Compliance Records";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/"><i class="bi bi-heart-pulse"></i> WelfareLink</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Audits/Index">Audits</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/Compliance/Index">Compliance</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Users/Index">Users</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1><i class="bi bi-file-earmark-check"></i> Compliance Records</h1>
            <a href="/Compliance/Create" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> New Record
            </a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="row g-4">
            @if (Model.Records.Any())
            {
                @foreach (var record in Model.Records)
                {
                    <div class="col-md-4">
                        <div class="card h-100 shadow-sm">
                            <div class="card-header bg-@(record.Result == "Pass" ? "success" : record.Result == "Fail" ? "danger" : "warning") text-white">
                                <h5 class="mb-0">@record.Type</h5>
                            </div>
                            <div class="card-body">
                                <p><strong>Entity:</strong> @record.EntityID.Substring(0, Math.Min(8, record.EntityID.Length))</p>
                                <p><strong>Date:</strong> @record.Date.ToString("MMM dd, yyyy")</p>
                                <p><strong>Result:</strong> <span class="badge bg-@(record.Result == "Pass" ? "success" : "danger")">@record.Result</span></p>
                                <p class="mb-0"><strong>Notes:</strong></p>
                                <p class="text-muted small">@(string.IsNullOrEmpty(record.Notes) ? "No notes" : record.Notes)</p>
                            </div>
                            <div class="card-footer">
                                <a href="/Compliance/Details/@record.ComplianceID" class="btn btn-sm btn-outline-info">View</a>
                                <a href="/Compliance/Edit/@record.ComplianceID" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a href="/Compliance/Delete/@record.ComplianceID" class="btn btn-sm btn-outline-danger">Delete</a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="card shadow-sm">
                        <div class="card-body text-center p-5">
                            <i class="bi bi-inbox" style="font-size: 4rem; color: #ccc;"></i>
                            <p class="mt-3 text-muted">No compliance records found</p>
                            <a href="/Compliance/Create" class="btn btn-success">
                                <i class="bi bi-plus-circle"></i> Create First Record
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
