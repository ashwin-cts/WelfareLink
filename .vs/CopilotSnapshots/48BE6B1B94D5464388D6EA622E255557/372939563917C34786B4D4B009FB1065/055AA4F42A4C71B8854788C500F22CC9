@model WelfareLink.Models.WelfareApplication

@{
    ViewData["Title"] = "Application Details";
}

<div class="page-header">
    <div>
        <h1>
            <i class="bi bi-file-earmark-text"></i>
            Application Details
        </h1>
        <p class="mb-0">
            <strong>Application #@Model.ApplicationID</strong>
            @if (Model.Program != null)
            {
                <span> - @Model.Program.Title</span>
            }
        </p>
        @if (Model.Citizen != null)
        {
            <small class="text-muted">Applicant: @Model.Citizen.Name</small>
        }
    </div>
    <div class="action-buttons">
        <a asp-action="Index" class="btn btn-modern btn-secondary-modern">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
            <div class="col-md-8">
                <div class="content-card mb-3">
                    <h4 class="mb-3"><i class="bi bi-info-circle"></i> Application Information</h4>
                    <div class="detail-grid">
                        <div class="detail-item">
                            <label>Application ID</label>
                            <p><strong>#@Model.ApplicationID</strong></p>
                        </div>

                        <div class="detail-item">
                            <label>Citizen Name</label>
                            <p>
                                @if (Model.Citizen != null)
                                {
                                    <i class="bi bi-person-fill text-primary"></i> @Model.Citizen.Name
                                    <br />
                                    <small class="text-muted">ID: #@Model.CitizenID</small>
                                }
                                else
                                {
                                    <span>Citizen ID: @Model.CitizenID</span>
                                }
                            </p>
                        </div>

                        <div class="detail-item">
                            <label>Program Name</label>
                            <p>
                                @if (Model.Program != null)
                                {
                                    <i class="bi bi-diagram-3-fill text-info"></i> @Model.Program.Title
                                    <br />
                                    <small class="text-muted">ID: #@Model.ProgramID</small>
                                }
                                else
                                {
                                    <span>Program ID: @Model.ProgramID</span>
                                }
                            </p>
                        </div>

                        <div class="detail-item">
                            <label>Submitted Date</label>
                            <p><i class="bi bi-calendar-event"></i> @Model.SubmittedDate.ToString("dd MMMM yyyy")</p>
                        </div>

                        <div class="detail-item">
                            <label>Current Status</label>
                            <p>
                                @if (Model.Status == "Pending")
                                {
                                    <span class="status-badge status-pending"><i class="bi bi-clock"></i> Pending</span>
                                }
                                else if (Model.Status == "Approved")
                                {
                                    <span class="status-badge status-fully-disbursed"><i class="bi bi-check-circle"></i> Approved</span>
                                }
                                else if (Model.Status == "Rejected")
                                {
                                    <span class="status-badge status-failed"><i class="bi bi-x-circle"></i> Rejected</span>
                                }
                                else if (Model.Status == "Fully Disbursed")
                                {
                                    <span class="status-badge status-fully-disbursed"><i class="bi bi-patch-check-fill"></i> Fully Disbursed</span>
                                }
                                else
                                {
                                    <span class="status-badge status-processing">@Model.Status</span>
                                }
                            </p>
                        </div>
                    </div>
                </div>

                <div class="content-card">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="mb-0"><i class="bi bi-clipboard-check"></i> Eligibility Check History</h4>
                        <a asp-controller="EligibilityCheck" asp-action="Create" asp-route-applicationId="@Model.ApplicationID"
                           class="btn btn-modern btn-primary-modern btn-sm">
                            <i class="bi bi-plus-circle"></i> New Check
                        </a>
                    </div>
                    @if (Model.EligibilityChecks != null && Model.EligibilityChecks.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-modern">
                                <thead>
                                    <tr>
                                        <th>Check ID</th>
                                        <th>Date</th>
                                        <th>Officer ID</th>
                                        <th>Result</th>
                                        <th>Result Code</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var check in Model.EligibilityChecks.OrderByDescending(c => c.Date))
                                    {
                                        <tr>
                                            <td><span class="badge bg-secondary">#@check.CheckID</span></td>
                                            <td>@check.Date.ToString("dd MMM yyyy")</td>
                                            <td>@check.OfficerID</td>
                                            <td>
                                                @if (check.Result.Equals("Eligible", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <span class="status-badge status-fully-disbursed"><i class="bi bi-check-circle"></i> Eligible</span>
                                                }
                                                else
                                                {
                                                    <span class="status-badge status-failed"><i class="bi bi-x-circle"></i> Ineligible</span>
                                                }
                                            </td>
                                            <td><code>@check.ResultCode</code></td>
                                            <td>
                                                <a asp-controller="EligibilityCheck" asp-action="Details" asp-route-id="@check.CheckID"
                                                   class="btn btn-sm btn-modern btn-info-modern" title="View Details">
                                                    <i class="bi bi-eye"></i> View
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle"></i>
                            No eligibility checks have been performed for this application yet.
                            <br />
                            <a asp-controller="EligibilityCheck" asp-action="Create" asp-route-applicationId="@Model.ApplicationID"
                               class="btn btn-modern btn-primary-modern btn-sm mt-2">
                                <i class="bi bi-clipboard-check"></i> Perform Eligibility Check
                            </a>
                        </div>
                    }
                </div>
            </div>

            <div class="col-md-4">
                <div class="content-card mb-3">
                    <h5 class="mb-3"><i class="bi bi-gear"></i> Actions</h5>
                    <div class="d-grid gap-2">
                        <button type="button" class="btn btn-modern btn-success-modern" data-bs-toggle="modal" data-bs-target="#updateStatusModal">
                            <i class="bi bi-arrow-repeat"></i> Update Status
                        </button>

                        <a asp-controller="EligibilityCheck" asp-action="Create" asp-route-applicationId="@Model.ApplicationID"
                           class="btn btn-modern btn-primary-modern">
                            <i class="bi bi-clipboard-check"></i> Eligibility Check
                        </a>
                    </div>
                </div>

                <div class="content-card">
                    <h5 class="mb-3"><i class="bi bi-clock-history"></i> Application Timeline</h5>
                    <div class="timeline">
                        <div class="timeline-item">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-success me-2" style="font-size: 1.2rem;"></i>
                                <div>
                                    <strong>Submitted</strong>
                                    <br />
                                    <small class="text-muted">@Model.SubmittedDate.ToString("dd MMM yyyy")</small>
                                </div>
                            </div>
                        </div>

                        @if (Model.Status == "Approved" || Model.Status == "Rejected")
                        {
                            <div class="timeline-item mt-3">
                                <div class="d-flex align-items-center">
                                    @if (Model.Status == "Approved")
                                    {
                                        <i class="bi bi-check-circle-fill text-success me-2" style="font-size: 1.2rem;"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-x-circle-fill text-danger me-2" style="font-size: 1.2rem;"></i>
                                    }
                                    <div>
                                        <strong>@Model.Status</strong>
                                        <br />
                                        <small class="text-muted">Status updated</small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

<!-- Update Status Modal -->
<div class="modal fade" id="updateStatusModal" tabindex="-1" aria-labelledby="updateStatusModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="updateStatusModalLabel">Update Application Status</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="UpdateStatus" method="post">
                <input type="hidden" name="id" value="@Model.ApplicationID" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="status" class="form-label">Select New Status</label>
                        <select name="status" id="status" class="form-select" required>
                            <option value="">Choose...</option>
                            <option value="Pending">Pending</option>
                            <option value="Under Review">Under Review</option>
                            <option value="Approved">Approved</option>
                            <option value="Rejected">Rejected</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update Status</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
