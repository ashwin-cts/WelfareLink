@model IEnumerable<WelfareLink.Models.WelfareApplication>

@{
    ViewData["Title"] = "WelfareLink - Home";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="display-4">Welfare Application Management System</h1>
            <p class="lead">Manage and track welfare applications</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h5 class="card-title">Total Applications</h5>
                    <h2>@Model.Count()</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <h5 class="card-title">Pending</h5>
                    <h2>@Model.Count(a => a.Status == "Pending")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5 class="card-title">Approved</h5>
                    <h2>@Model.Count(a => a.Status == "Approved")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-danger">
                <div class="card-body">
                    <h5 class="card-title">Rejected</h5>
                    <h2>@Model.Count(a => a.Status == "Rejected")</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Applications Table -->
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h5><i class="bi bi-list-ul"></i> Welfare Applications List</h5>
                </div>
                <div class="card-body">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Application ID</th>
                                        <th>Citizen ID</th>
                                        <th>Program</th>
                                        <th>Submitted Date</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td><strong>#@item.ApplicationID</strong></td>
                                            <td>@item.CitizenID</td>
                                            <td>
                                                @if (item.Program != null)
                                                {
                                                    <a asp-controller="WelfareProgram" asp-action="Details" asp-route-id="@item.ProgramID"
                                                       class="text-decoration-none">
                                                        <span class="badge bg-primary">
                                                            <i class="bi bi-clipboard"></i> @item.Program.Title
                                                        </span>
                                                    </a>
                                                    <br /><small class="text-muted">#@item.ProgramID</small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">#@item.ProgramID</span>
                                                }
                                            </td>
                                            <td>@item.SubmittedDate.ToString("dd MMM yyyy")</td>
                                            <td>
                                                @if (item.Status == "Pending")
                                                {
                                                    <span class="badge bg-warning text-dark">@item.Status</span>
                                                }
                                                else if (item.Status == "Approved")
                                                {
                                                    <span class="badge bg-success">@item.Status</span>
                                                }
                                                else if (item.Status == "Rejected")
                                                {
                                                    <span class="badge bg-danger">@item.Status</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-info">@item.Status</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a asp-controller="WelfareApplication" asp-action="Details" asp-route-id="@item.ApplicationID"
                                                           class="btn btn-sm btn-info" title="View Details">
                                                        <i class="bi bi-eye"></i> View
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info text-center">
                            <i class="bi bi-info-circle"></i>
                            <strong>No applications found.</strong> Submit your first application using the form above.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
