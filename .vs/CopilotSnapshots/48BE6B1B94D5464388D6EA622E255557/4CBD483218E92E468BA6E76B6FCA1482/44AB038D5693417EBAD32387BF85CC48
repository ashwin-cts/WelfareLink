@model WelfareLink.Models.WelfareApplication

@{
    ViewData["Title"] = "Application Details";
}

<div class="page-header">
    <div>
        <h1>
            <i class="bi bi-file-earmark-text"></i>
            Application Details
        </h1>
        <p class="mb-0">
            <strong>Application #@Model.ApplicationID</strong>
            @if (Model.Program != null)
            {
                <span> - @Model.Program.Title</span>
            }
        </p>
        @if (Model.Citizen != null)
        {
            <small class="text-muted">Applicant: @Model.Citizen.Name</small>
        }
    </div>
    <div class="action-buttons">
        <a asp-action="Index" class="btn btn-modern btn-secondary-modern">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
        <div class="col-md-8">
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">
                    <h5>Application Information</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Application ID</dt>
                        <dd class="col-sm-8"><strong>#@Model.ApplicationID</strong></dd>

                        <dt class="col-sm-4">Citizen Name</dt>
                        <dd class="col-sm-8">
                            @if (Model.Citizen != null)
                            {
                                <i class="bi bi-person-fill text-primary"></i> @Model.Citizen.Name
                                <br />
                                <small class="text-muted">Citizen ID: #@Model.CitizenID</small>
                            }
                            else
                            {
                                <span>Citizen ID: @Model.CitizenID</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Program Name</dt>
                        <dd class="col-sm-8">
                            @if (Model.Program != null)
                            {
                                <i class="bi bi-diagram-3-fill text-info"></i> @Model.Program.Title
                                <br />
                                <small class="text-muted">Program ID: #@Model.ProgramID</small>
                            }
                            else
                            {
                                <span>Program ID: @Model.ProgramID</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Submitted Date</dt>
                        <dd class="col-sm-8"><i class="bi bi-calendar-event"></i> @Model.SubmittedDate.ToString("dd MMMM yyyy")</dd>

                        <dt class="col-sm-4">Current Status</dt>
                        <dd class="col-sm-8">
                            @if (Model.Status == "Pending")
                            {
                                <span class="badge bg-warning text-dark fs-6"><i class="bi bi-clock"></i> @Model.Status</span>
                            }
                            else if (Model.Status == "Approved")
                            {
                                <span class="badge bg-success fs-6"><i class="bi bi-check-circle"></i> @Model.Status</span>
                            }
                            else if (Model.Status == "Rejected")
                            {
                                <span class="badge bg-danger fs-6"><i class="bi bi-x-circle"></i> @Model.Status</span>
                            }
                            else if (Model.Status == "Fully Disbursed")
                            {
                                <span class="badge fs-6" style="background-color:#0d6efd"><i class="bi bi-patch-check-fill"></i> @Model.Status</span>
                            }
                            else
                            {
                                <span class="badge bg-info fs-6">@Model.Status</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-clipboard-check"></i> Eligibility Check History</h5>
                    <a asp-controller="EligibilityCheck" asp-action="Create" asp-route-applicationId="@Model.ApplicationID"
                       class="btn btn-sm btn-primary">
                        <i class="bi bi-plus-circle"></i> New Check
                    </a>
                </div>
                <div class="card-body p-0">
                    @if (Model.EligibilityChecks != null && Model.EligibilityChecks.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover mb-0">
                                <thead class="table-dark">
                                    <tr>
                                        <th><i class="bi bi-hash"></i> Check ID</th>
                                        <th><i class="bi bi-calendar"></i> Date</th>
                                        <th><i class="bi bi-person-badge"></i> Officer ID</th>
                                        <th><i class="bi bi-flag"></i> Result</th>
                                        <th><i class="bi bi-code-square"></i> Result Code</th>
                                        <th><i class="bi bi-gear"></i> Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var check in Model.EligibilityChecks.OrderByDescending(c => c.Date))
                                    {
                                        <tr>
                                            <td><span class="badge bg-secondary">#@check.CheckID</span></td>
                                            <td>@check.Date.ToString("dd MMM yyyy")</td>
                                            <td>@check.OfficerID</td>
                                            <td>
                                                @if (check.Result.Equals("Eligible", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <span class="badge bg-success"><i class="bi bi-check-circle"></i> @check.Result</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger"><i class="bi bi-x-circle"></i> @check.Result</span>
                                                }
                                            </td>
                                            <td><code>@check.ResultCode</code></td>
                                            <td>
                                                <a asp-controller="EligibilityCheck" asp-action="Details" asp-route-id="@check.CheckID"
                                                   class="btn btn-sm btn-outline-info" title="View Details">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="p-3">
                            <p class="text-muted mb-3">
                                <i class="bi bi-info-circle"></i>
                                No eligibility checks have been performed for this application yet.
                            </p>
                            <a asp-controller="EligibilityCheck" asp-action="Create" asp-route-applicationId="@Model.ApplicationID"
                               class="btn btn-primary">
                                <i class="bi bi-clipboard-check"></i> Perform Eligibility Check
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header">
                    <h5>Actions</h5>
                </div>
                <div class="card-body d-grid gap-2">
                    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#updateStatusModal">
                        <i class="bi bi-arrow-repeat"></i> Update Status
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5>Application Timeline</h5>
                </div>
                <div class="card-body">
                    <div class="timeline">
                        <div class="timeline-item">
                            <i class="bi bi-check-circle-fill text-success"></i>
                            <strong>Submitted</strong>
                            <br />
                            <small>@Model.SubmittedDate.ToString("dd MMM yyyy")</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Update Status Modal -->
<div class="modal fade" id="updateStatusModal" tabindex="-1" aria-labelledby="updateStatusModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="updateStatusModalLabel">Update Application Status</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="UpdateStatus" method="post">
                <input type="hidden" name="id" value="@Model.ApplicationID" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="status" class="form-label">Select New Status</label>
                        <select name="status" id="status" class="form-select" required>
                            <option value="">Choose...</option>
                            <option value="Pending">Pending</option>
                            <option value="Under Review">Under Review</option>
                            <option value="Approved">Approved</option>
                            <option value="Rejected">Rejected</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update Status</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
