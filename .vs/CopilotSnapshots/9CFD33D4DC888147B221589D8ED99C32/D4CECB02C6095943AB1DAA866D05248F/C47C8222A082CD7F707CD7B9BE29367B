@model WelfareLink.Models.EligibilityCheck

@{
    ViewData["Title"] = "Eligibility Check Details";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="display-4">@ViewData["Title"]</h1>
            <p class="lead">Check ID: @Model.CheckID</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">
                    <h5>Assessment Information</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Check ID</dt>
                        <dd class="col-sm-8">@Model.CheckID</dd>

                        <dt class="col-sm-4">Application ID</dt>
                        <dd class="col-sm-8">
                            <a asp-controller="WelfareApplication" asp-action="Details" asp-route-id="@Model.ApplicationID" 
                               class="badge bg-primary fs-6 text-decoration-none">
                                #@Model.ApplicationID
                            </a>
                        </dd>

                        @if (Model.WelfareApplication != null)
                        {
                            <dt class="col-sm-4">Citizen ID</dt>
                            <dd class="col-sm-8">@Model.WelfareApplication.CitizenID</dd>

                            <dt class="col-sm-4">Program</dt>
                            <dd class="col-sm-8">
                                @if (Model.WelfareApplication.Program != null)
                                {
                                    <span>@Model.WelfareApplication.Program.Title</span>
                                    <small class="text-muted d-block">ID: @Model.WelfareApplication.ProgramID</small>
                                }
                                else
                                {
                                    <span>#@Model.WelfareApplication.ProgramID</span>
                                }
                            </dd>

                            <dt class="col-sm-4">Submitted Date</dt>
                            <dd class="col-sm-8">@Model.WelfareApplication.SubmittedDate.ToString("dd MMMM yyyy")</dd>

                            <dt class="col-sm-4">Application Status</dt>
                            <dd class="col-sm-8"><span class="badge bg-secondary">@Model.WelfareApplication.Status</span></dd>
                        }

                        <dt class="col-sm-4">Officer ID</dt>
                        <dd class="col-sm-8">@Model.OfficerID</dd>

                        <dt class="col-sm-4">Assessment Date</dt>
                        <dd class="col-sm-8">@Model.Date.ToString("dd MMMM yyyy")</dd>

                        <dt class="col-sm-4">Result</dt>
                        <dd class="col-sm-8">
                            @if (Model.Result.ToLower() == "eligible")
                            {
                                <span class="badge bg-success fs-6">@Model.Result</span>
                            }
                            else
                            {
                                <span class="badge bg-danger fs-6">@Model.Result</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Result Code</dt>
                        <dd class="col-sm-8"><span class="badge bg-secondary fs-6">@Model.ResultCode</span></dd>

                        <dt class="col-sm-4">Assessment Notes</dt>
                        <dd class="col-sm-8">@Model.Notes</dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5>Actions</h5>
                </div>
                <div class="card-body d-grid gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.CheckID" class="btn btn-warning">
                        <i class="bi bi-pencil"></i> Edit Check
                    </a>

                    <a asp-action="Delete" asp-route-id="@Model.CheckID" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Delete Check
                    </a>

                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
