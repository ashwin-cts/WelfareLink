@model WelfareLink.Models.WelfareApplication

@{
    ViewData["Title"] = "Application Details";
    var canEdit   = Model.Status == "Pending" || Model.Status == "Rejected";
    var canDelete = Model.Status == "Pending";
    var statusClass = Model.Status?.ToLower() switch
    {
        "approved"     => "status-fully-disbursed",
        "pending"      => "status-pending",
        "under review" => "status-processing",
        "rejected"     => "status-failed",
        _              => "status-pending"
    };
}

<div class="page-header">
    <h1><i class="bi bi-file-earmark-text-fill"></i> Application #@Model.ApplicationID</h1>
    <a asp-controller="Citizen" asp-action="MyApplications" class="btn-modern btn-secondary-modern">
        <i class="bi bi-arrow-left"></i> Back to My Applications
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="content-card">
    <!-- Status Banner -->
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center"
             style="width:60px;height:60px;flex-shrink:0;">
            <i class="bi bi-file-earmark-person-fill text-white" style="font-size:1.8rem;"></i>
        </div>
        <div>
            <h4 class="mb-1">Application #@Model.ApplicationID</h4>
            <span class="status-badge @statusClass">
                <i class="bi bi-circle-fill" style="font-size:8px;"></i> @Model.Status
            </span>
            @if (Model.Status == "Rejected")
            {
                <span class="ms-2 text-warning small"><i class="bi bi-info-circle"></i> You may edit and re-submit this application.</span>
            }
            @if (Model.Status is "Under Review" or "Approved")
            {
                <span class="ms-2 text-muted small"><i class="bi bi-lock-fill"></i> Editing is locked while your application is being processed.</span>
            }
        </div>
    </div>

    <!-- Details Grid -->
    <div class="detail-grid mb-4">
        <div class="detail-item">
            <label><i class="bi bi-hash"></i> Application ID</label>
            <p>#@Model.ApplicationID</p>
        </div>
        <div class="detail-item">
            <label><i class="bi bi-person-badge"></i> Citizen ID</label>
            <p>#@Model.CitizenID</p>
        </div>
        <div class="detail-item">
            <label><i class="bi bi-diagram-3"></i> Program</label>
            <p>@(Model.Program?.Title ?? $"Program #{Model.ProgramID}")</p>
        </div>
        <div class="detail-item">
            <label><i class="bi bi-calendar-event"></i> Submitted Date</label>
            <p>@Model.SubmittedDate.ToString("dd MMMM yyyy")</p>
        </div>
        <div class="detail-item">
            <label><i class="bi bi-flag"></i> Current Status</label>
            <p><span class="status-badge @statusClass"><i class="bi bi-circle-fill" style="font-size:8px;"></i> @Model.Status</span></p>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="d-flex gap-3 flex-wrap">
        @if (canEdit)
        {
            <a asp-controller="Citizen" asp-action="EditApplication" asp-route-id="@Model.ApplicationID"
               class="btn-modern btn-warning-modern">
                <i class="bi bi-pencil-square"></i>
                @(Model.Status == "Rejected" ? "Edit & Re-submit" : "Edit Application")
            </a>
        }
        else
        {
            <button class="btn-modern btn-warning-modern" disabled title="Editing is locked for this status" style="opacity:.5;cursor:not-allowed;">
                <i class="bi bi-lock-fill"></i> Edit Application
            </button>
        }

        @if (canDelete)
        {
            <a asp-controller="Citizen" asp-action="DeleteApplication" asp-route-id="@Model.ApplicationID"
               class="btn-modern btn-danger-modern">
                <i class="bi bi-trash"></i> Delete Application
            </a>
        }
    </div>
</div>
