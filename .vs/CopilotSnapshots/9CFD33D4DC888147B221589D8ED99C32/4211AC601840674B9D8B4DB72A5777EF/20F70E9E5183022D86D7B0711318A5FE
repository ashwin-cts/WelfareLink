@model IEnumerable<WelfareLink.Models.WelfareApplication>

@{
    ViewData["Title"] = "My Applications";
}

<div class="page-header">
    <h1><i class="bi bi-person-lines-fill"></i> My Applications</h1>
    <a asp-controller="Citizen" asp-action="ProgramList" class="btn-modern btn-success-modern">
        <i class="bi bi-grid-3x3-gap"></i> Apply New Welfare Program
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="content-card">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox" style="font-size: 4rem; color: #cbd5e1;"></i>
            <h4 class="mt-3 text-muted">No applications yet</h4>
            <p class="text-muted">You haven't applied for any welfare program yet.</p>
            <a asp-controller="Citizen" asp-action="ProgramList" class="btn-modern btn-primary-modern">
                <i class="bi bi-grid-3x3-gap"></i> Browse Available Programs
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-modern">
                <thead>
                    <tr>
                        <th><i class="bi bi-hash"></i> Application ID</th>
                        <th><i class="bi bi-diagram-3"></i> Program</th>
                        <th><i class="bi bi-calendar-event"></i> Submitted Date</th>
                        <th><i class="bi bi-flag"></i> Status</th>
                        <th><i class="bi bi-gear"></i> Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            @{
                                var statusClass = item.Status?.ToLower() switch
                            {
                                "approved"     => "status-fully-disbursed",
                                "pending"      => "status-pending",
                                "under review" => "status-processing",
                                "rejected"     => "status-failed",
                                _              => "status-pending"
                            };
                        }
                        <td><strong>#@item.ApplicationID</strong></td>
                            <td>
                                @if (item.Program != null)
                                {
                                    <strong>@item.Program.Title</strong>
                                    <br /><small class="text-muted">#@item.ProgramID</small>
                                }
                                else
                                {
                                    <span>Program #@item.ProgramID</span>
                                }
                            </td>
                            <td>@item.SubmittedDate.ToString("dd MMM yyyy")</td>
                            <td>
                                <span class="status-badge @statusClass">
                                    <i class="bi bi-circle-fill" style="font-size: 8px;"></i> @item.Status
                                </span>
                            </td>
                            <td>
                                <a asp-controller="Citizen" asp-action="ApplicationDetails" asp-route-id="@item.ApplicationID"
                                   class="btn-modern btn-info-modern btn-sm" title="View Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
