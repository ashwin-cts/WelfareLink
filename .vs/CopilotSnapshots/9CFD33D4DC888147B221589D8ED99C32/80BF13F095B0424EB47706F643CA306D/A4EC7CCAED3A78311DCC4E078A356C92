using Microsoft.EntityFrameworkCore;
using WelfareLink.Data;
using WelfareLink.Interfaces;
using WelfareLink.Models;


namespace WelfareLink.Repositories
{
    public class DisbursementRepository : IDisbursementRepository
    {
        private readonly WelfareLinkDbContext _context;

        public DisbursementRepository(WelfareLinkDbContext context)
        {
            _context = context;
        }

        public async Task<IEnumerable<Disbursement>> GetAllAsync()
        {
            return await _context.Disbursements
                .AsNoTracking()
                .Include(d => d.Benefit)
                    .ThenInclude(b => b.WelfareApplication)
                        .ThenInclude(a => a.Citizen)
                .Include(d => d.Benefit)
                    .ThenInclude(b => b.WelfareApplication)
                        .ThenInclude(a => a.Program)
                .ToListAsync();
        }

        public async Task<Disbursement?> GetByIdAsync(int id)
        {
            return await _context.Disbursements
                .AsNoTracking()
                .Include(d => d.Benefit)
                    .ThenInclude(b => b.WelfareApplication)
                        .ThenInclude(a => a.Citizen)
                .Include(d => d.Benefit)
                    .ThenInclude(b => b.WelfareApplication)
                        .ThenInclude(a => a.Program)
                .FirstOrDefaultAsync(d => d.DisbursementID == id);
        }

        public async Task<Disbursement> AddAsync(Disbursement disbursement)
        {
            _context.Disbursements.Add(disbursement);
            await _context.SaveChangesAsync();
            return disbursement;
        }

        public async Task<Disbursement> UpdateAsync(Disbursement disbursement)
        {
            var trackedEntity = _context.ChangeTracker.Entries<Disbursement>()
                .FirstOrDefault(e => e.Entity.DisbursementID == disbursement.DisbursementID);

            if (trackedEntity != null)
            {
                trackedEntity.State = EntityState.Detached;
            }

            _context.Entry(disbursement).State = EntityState.Modified;
            await _context.SaveChangesAsync();
            return disbursement;
        }

        public async Task<bool> DeleteAsync(int id)
        {
            var disbursement = await _context.Disbursements.FindAsync(id);
            if (disbursement == null)
            {
                return false;
            }

            _context.Disbursements.Remove(disbursement);
            await _context.SaveChangesAsync();
            return true;
        }

        public async Task<bool> ExistsAsync(int id)
        {
            return await _context.Disbursements.AnyAsync(d => d.DisbursementID == id);
        }

        public async Task<IEnumerable<Disbursement>> GetByBenefitIdAsync(int benefitId)
        {
            return await _context.Disbursements
                .AsNoTracking()
                .Include(d => d.Benefit)
                .Where(d => d.BenefitID == benefitId)
                .ToListAsync();
        }
    }
}